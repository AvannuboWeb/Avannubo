---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';

const glassbox =
  'overflow-hidden rounded-[20px] bg-[rgba(120,120,120,0.5)] shadow-[0_0_10px_rgba(0,0,0,0.5)] backdrop-blur-[30px]';

const buttons =
  'relative z-[1] mt-8 inline-flex min-h-[45px] cursor-pointer items-center justify-center rounded-[10px] bg-[#b60000] font-medium px-4 py-3 leading-none transition-all duration-[220ms] ease-in-out hover:-translate-y-0.5 hover:bg-[#3d3d3c]';
const buttons2 =
  'relative z-[1] mt-8 inline-flex min-h-[45px] cursor-pointer items-center justify-center rounded-[10px] bg-transparent font-medium px-4 py-3 leading-none transition-all duration-[220ms] ease-in-out border-2 border-white hover:-translate-y-0.5 hover:bg-[#3d3d3c] hover:border-transparent';
