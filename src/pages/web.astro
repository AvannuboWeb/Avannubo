  );

  let webServiceTabsActive = false;

  const resetWebServiceZIndexes = () => {
    webServiceCards.forEach((item) => {
      item.style.zIndex = item.dataset.baseZ ?? '';
    });
  };

  const updateWebServiceTabsState = () => {
    if (!lastWebServiceCard) return;

    const stickyTop =
      Number.parseFloat(window.getComputedStyle(lastWebServiceCard).top) || 0;
    const isLastCardAtStickyTop =
      lastWebServiceCard.getBoundingClientRect().top <= stickyTop + 1;

    if (!isLastCardAtStickyTop && webServiceTabsActive) {
      resetWebServiceZIndexes();
    }

    webServiceTabsActive = isLastCardAtStickyTop;

    webServiceTabs.forEach((tab) => {
      tab.classList.toggle('cursor-pointer', webServiceTabsActive);
      tab.classList.toggle('cursor-default', !webServiceTabsActive);
    });
  };

  webServiceCards.forEach((card) => {
    const tab = card.querySelector<HTMLButtonElement>('.js-web-service-tab');

    tab?.addEventListener('click', () => {
      updateWebServiceTabsState();

      if (!webServiceTabsActive) return;

      resetWebServiceZIndexes();
      card.style.zIndex = '100';
    });
  });

  window.addEventListener('scroll', updateWebServiceTabsState, {
    passive: true,
  });
  window.addEventListener('resize', updateWebServiceTabsState);
  updateWebServiceTabsState();

  const successHorizontalSection = document.querySelector<HTMLElement>(
    '.js-success-horizontal-section'
  );
  const successHorizontalViewport = document.querySelector<HTMLElement>(
    '.js-success-horizontal-viewport'
  );
  const successHorizontalTrack = document.querySelector<HTMLElement>(
    '.js-success-horizontal-track'
  );

  const updateSuccessHorizontalScroll = () => {
    if (
      !successHorizontalSection ||
      !successHorizontalViewport ||
      !successHorizontalTrack
    ) {
      return;
    }

    const sectionTop = successHorizontalSection.offsetTop;
    const verticalScrollDistance =
      successHorizontalSection.offsetHeight - window.innerHeight;
    const horizontalScrollDistance =
      successHorizontalTrack.scrollWidth -
      successHorizontalViewport.clientWidth;

    if (verticalScrollDistance <= 0 || horizontalScrollDistance <= 0) return;

    const progress = Math.min(
      Math.max((window.scrollY - sectionTop) / verticalScrollDistance, 0),
      1
    );

    successHorizontalTrack.style.transform = `translate3d(${-progress * horizontalScrollDistance}px, 0, 0)`;
  };

  window.addEventListener('scroll', updateSuccessHorizontalScroll, {
    passive: true,
  });
  window.addEventListener('resize', updateSuccessHorizontalScroll);
  updateSuccessHorizontalScroll();
</script>
