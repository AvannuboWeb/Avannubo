---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';

const glassbox =
  'overflow-hidden rounded-[20px] bg-[rgba(120,120,120,0.5)] shadow-[0_0_10px_rgba(0,0,0,0.5)] backdrop-blur-[30px]';
const serviceCard = `sticky flex h-[55vh] w-full flex-col items-start justify-between p-5 transition-[width] duration-400 ease-out ${glassbox}`;
const serviceTitle =
  'm-0 text-[7vh] font-bold leading-[0.95] text-white transition-all duration-200 ease-in-out hover:translate-x-0.5 hover:text-[#b60000]';
const serviceArrow =
  'flex h-[6vh] w-[6vh] items-center justify-center rounded-[10px] bg-[#b60000] text-[5vh] leading-none shadow-[0_0_10px_rgba(0,0,0,0.4)] transition-all duration-200 ease-in-out hover:translate-x-0.5 hover:-translate-y-0.5 hover:bg-black';
const contactButton =
  'relative z-[1] mt-8 inline-flex min-h-[45px] font-medium cursor-pointer items-center justify-center rounded-[10px] bg-[#b60000] px-4 py-3 leading-none transition-all duration-[220ms] ease-in-out hover:-translate-y-0.5 ';

const certifications = [
  { src: '/9001.png', alt: '9001', className: 'h-auto w-[70px]' },
  { src: '/27001.png', alt: '27001', className: 'h-auto w-[70px]' },
  { src: '/ENS.png', alt: 'ENS', className: 'h-auto w-[70px]' },
  { src: '/CNMC_logo.webp', alt: 'CNMC', className: 'h-auto w-[220px]' },
];

const infrastructureServices = [
  {
    title: 'DATA-CENTER',
    href: '/data-center',
    image: '/homeimg/data-center.webp',
    alt: 'Data Center',
    topClass: 'top-[7vh]',
    description:
      'Soluciones de cloud empresarial, virtualización, almacenamiento seguro y continuidad de negocio, todo ello con máxima seguridad y alto rendimiento.',
    items: [
      'CloudAVAN y AVANvault',
      'Suministros Hardware y Software',
      'Migraciones y Planes Backup y DRS',
      'Citrix (Entorno de Virtualización)',
      'Infraestructura y Housing',
      'AVANréplica (replicación en tiempo real)',
    ],
  },
  {
    title: 'SISTEMAS',
    href: '/sistemas',
    image: '/homeimg/sistemas.webp',
    alt: 'Sistemas',
    topClass: 'top-[16vh]',
    description:
      'Somos expertos en sistemas y administración IT, por lo que garantizamos continuidad, productividad y protección con las mejores herramientas.',
    items: [
      'Mantenimiento y Monitorización',
      'Helpdesk y soporte',
      'Ciberseguridad',
      'Gestión de proyectos IT',
      'Microsoft 365',
      'AVANdns (Dominios y DNS)',
    ],
  },
  {
    title: 'REDES',
    href: '/redes',
    image: '/homeimg/redes.webp',
    alt: 'REDES',
    topClass: 'top-[25vh]',
    description:
      'Potenciamos tu infraestructura: analizamos, optimizamos e implementamos redes desde cero, garantizando la máxima seguridad y rendimiento.',
    items: [
      'Soporte y Asistencia Técnica',
      'Diseño y Planificación de Redes',
      'Seguridad y Protección de Redes',
      'Optimización y Rendimiento',
      'Mantenimiento y Monitorización',
    ],
  },
  {
    title: 'TELEFONÍA IP',
    href: '/telefonia',
    image: '/homeimg/telefonia.webp',
    alt: 'Telefonía IP',
    topClass: 'top-[34vh]',
    description:
      'Sistema de telefonía IP profesional para empresas que buscan control, escalabilidad y, además, eficiencia en sus comunicaciones.',
    items: [
      'Servicios de Telefonía IP - AVANvoip',
      'Telefonía IP integrada - AVANmóvil',
      'Softphone y Extensiones - IPAVANsip',
      'AVANwave + CRM',
    ],
  },
  {
    title: 'INSTALACIONES',
    href: '/instalaciones',
    image: '/homeimg/instalaciones.webp',
    alt: 'Instalaciones',
    topClass: 'top-[43vh]',
    description:
      'Tu infraestructura en buenas manos gracias a instalaciones IT, seguridad y mantenimiento integral, garantizando así un funcionamiento continuo.',
    items: [
      'Consultoría y Asesoramiento Preventa',
      'Instalaciones y Cableados IT',
      'Sistemas de Red Wifi',
      'Saneado de Armarios Rack',
      'Controles de Accesos y CCTV',
      'Mantenimiento y Servicios postventa',
    ],
  },
];

const developmentServices = [
  {
    title: 'ODOO',
    href: '/odoo',
    image: '/homeimg/odoo.webp',
    alt: 'ODOO',
    topClass: 'top-[7vh]',
    description:
      'Adaptamos las herramientas de Odoo a las necesidades específicas de tu empresa. Optimiza procesos y mejora tu eficiencia.',
    items: [
      'Facturación electrónica - Verifactu y SII',
      'Automatización de Procesos',
      'Unificación de programas',
      'Reducción de costes',
      'Rendimiento y productividad',
    ],
  },
  {
    title: 'APLICACIONES',
    href: '/aplicaciones',
    image: '/homeimg/apps.webp',
    alt: 'Aplicaciones',
    topClass: 'top-[16vh]',
    description:
      'Impulsa tu negocio con aplicaciones web a medida, seguras y escalables. De la idea a producción, con calidad, rendimiento y soporte continuo.',
    items: [
      'Consultoría Técnica de Desarrollo',
      'Análisis funcional de procesos',
      'Arquitectura y diseño de software',
      'Desarrollo a medida y Despliegue',
      'Evolución y mantenimiento del software',
    ],
  },
  {
    title: 'DESARROLLO WEB',
    href: '/web',
    image: '/homeimg/web.webp',
    alt: 'Web',
    topClass: 'top-[25vh]',
    description:
      'Webs y comercios electrónicos rápidos, seguros y adaptados a tus necesidades y objetivos. Diseño personalizado, desarrollo y rendimiento.',
    items: [
      'Webs Corporativas a medida',
      'Tiendas Online a medida',
      'Mantenimeiento y Mejora',
      'Diseño de Web personalizado (UX/UI)',
      'Hosting propio y Certificados SSL',
    ],
  },
  {
    title: 'SEO & MARKETING',
    href: '/seo-marketing',
    image: '/homeimg/seo-marketing.webp',
    alt: 'SEO & Marketing',
    topClass: 'top-[34vh]',
    description:
      'Mejoramos tu presencia online con estrategias de SEO y Marketing efectivas, orientadas a optimizar resultados y aumentar la visibilidad.',
    items: [
      'Posicionamento SEO y GEO',
      'Analítica Web avanzada',
      'Estrategias SEM (Google Ads)',
      'Email Marketing',
      'Gestión de Redes Sociales',
      'Branding y Diseño Grafico',
    ],
  },
];

const avannetFeatures = [
  { icon: 'ph:headset-light', text: 'Ticketing y Asistencia' },
  { icon: 'ph:key-light', text: 'Contraseñas y Seguridad' },
  { icon: 'ph:file-text-light', text: 'Gestor de Documentos' },
  { icon: 'ph:users-light', text: 'Gestor de Empleados' },
  { icon: 'ph:calendar-check-light', text: 'Calendarios y Ausencias' },
  { icon: 'ph:fingerprint-light', text: 'Fichajes y Asistencias' },
  { icon: 'ph:chart-pie-light', text: 'CRM Comercial y Ventas' },
  { icon: 'ph:credit-card-light', text: 'Gestor de Clientes y Usuarios' },
];

const clientReviews = [
  {
    empresa: 'ICMR',
    nombre: 'Leyre Malet',
    logo: '/homeimg/Recepcion-logo.webp',
    text: 'Mi experiencia con Avannubo está siendo muy satisfactoria. Tienen una orientación a cliente muy cómoda para el usuario puesto que saben adaptarse y entender las necesidades perfectamente. Combinan un trato personalizado con unas capacidades integrales que lo hacen el perfecto colaborador. Todo el equipo es excepcional pero destaco la atención de Daniel Torrado por su trato exquisito.',
  },
  {
    empresa: 'Métodos Tiempos y Servicios S.L.',
    nombre: 'Mayte Sánchez',
    logo: '/Logo_Avannubo_header_bl.png',
    text: '«He migrado dominio y he tenido la gran suerte de que me hayan asignado a Daniel Torrado, un profesional y experto excepcional. No se si el resto del equipo es igual, pero me ha sorprendido gratamente y a mi es muy difícil sorprenderme. Recomiendo el servicio por mi propia experiencia.»',
  },
  {
    empresa: 'Grupo Aquacenter',
    nombre: 'Jordi Caballol',
    logo: '/Logo_Avannubo_header_bl.png',
    text: '«Como IT Manager del Grupo Aquacenter, estoy muy satisfecho del soporte que nos han aportado el equipo de redes de AVANCEM GRUP. Nunca había me había encontrado con un proveedor tan próximo que realmente te haga las cosas tan sencillas. Realmente sientes que puedes contar con ellos y que realmente, aún sin ponerles cara, sientes que forman parte de tu equipo.»',
  },
  {
    empresa: 'Recepción y Control de Alarmas S.L.',
    nombre: '',
    logo: '/Logo_Avannubo_header_bl.png',
    text: '«Experiencia muy positiva, tanto en relación al servicio técnico como con el departamento comercial, bien a distancia por el servicio de tickets como en la atención presencial. Resulta muy sencillo contactar con ellos, y dan respuestas de forma muy rápida y eficaz. En general, un servicio excelente.»',
  },
];
---

<BaseLayout
  title="Home"
  description="Inicio de AVNNUBO"
  mainClass="relative z-10 w-full p-0"
>
  <div class="relative z-10 w-full">
    <section
      class="flex min-h-screen w-full flex-col items-center justify-center"
      aria-label="Portada"
    >
      <h2
        id="typing-text"
        class="m-0 flex h-[120px] items-center text-[68px] font-normal leading-none"
      >
        <span id="typing-content"></span>
        <span
          class="ml-0.5 inline-block h-[120px] w-[3px] animate-pulse bg-white align-bottom"
        ></span>
      </h2>
      <h1 class="scroll-title m-0 text-[110px] font-bold leading-[1.05]">
        Soluciones y servicios IT
      </h1>
      <h2
        class="scroll-title-reverse mb-7 mt-0 text-[68px] font-normal leading-[1.1]"
      >
        que impulsan y transforman tu negocio
      </h2>
      <h3 class="mb-4 mt-0 text-3xl font-normal leading-[1.2]">
        Avannubo, your technology partner
      </h3>

      <a
        href="/calidad"
        aria-label="Certificaciones de calidad"
      >
        <div class="mt-8 flex flex-row items-center justify-center gap-2.5">
          {
            certifications.map((cert) => (
              <img
                src={cert.src}
                alt={cert.alt}
                class={cert.className}
              />
            ))
          }
        </div>
      </a>
      <div class="flex flex-row gap-6 mt-4">
        <a
          href="#mas"
          aria-label="descubre más"
          class={contactButton}
          >DESCUBRE MÁS
          <Icon
            name="ph:arrow-down-bold"
            class="h-5 w-5 ml-1.25"
          /></a
        >
        <a
          href="/contacto"
          aria-label="Contacto"
          class={contactButton}
          >EMPIEZA TU PROYECTO <Icon
            name="ph:arrow-right-bold"
            class="h-5 w-5 ml-1.25"
          /></a
        >
      </div>
    </section>

    <section
      class="relative flex w-full flex-col items-center justify-center px-10 py-40"
      aria-label="Partner tecnológico"
      id="mas"
    >
      <h3
        class="relative z-[1] m-0 w-[min(1200px,100%)] text-center text-4xl font-normal leading-[1.2]"
      >
        En <b>Avannubo</b>, queremos ser más que un proveedor de Soluciones y
        Servicios IT, queremos ser <b>Tu Partner Tecnológico</b>
      </h3>
      <img
        src="/avannubo_icon.png"
        alt=""
        class="absolute z-0 h-auto w-[440px] opacity-15"
        aria-hidden="true"
      />
    </section>

    <section
      class="relative flex w-full flex-col items-center justify-start px-20 py-[120px]"
      aria-label="Servicios"
    >
      <h2
        class="scroll-title mb-20 mt-0 text-center text-[68px] font-bold leading-[1.1]"
      >
        SERVICIOS AVANNUBO
      </h2>

      <div class="mb-[120px] flex w-full flex-col items-center justify-start">
        <h3
          class="sticky top-5 z-0 mb-10 mt-0 text-3xl font-bold leading-[1.2]"
        >
          Infraestructura y Conectividad
        </h3>
        {
          infrastructureServices.map((service, index) => (
            <article
              class={`${serviceCard} ${service.topClass} ${index === 0 ? 'mt-0' : 'mt-[120px]'}`}
            >
              <div class="flex w-full items-start justify-between">
                <a href={service.href}>
                  <h3 class={serviceTitle}>{service.title}</h3>
                </a>
                <a
                  href={service.href}
                  class={serviceArrow}
                  aria-label={service.title}
                >
                  <Icon
                    name="ph:arrow-up-right-light"
                    class="h-[4.2vh] w-[4.2vh]"
                  />
                </a>
              </div>
              <div class="flex min-h-0 w-full flex-row items-start justify-start gap-10">
                <img
                  src={service.image}
                  alt={service.alt}
                  class="h-[43vh] w-1/2 rounded-[20px] object-cover"
                />
                <div class="relative flex min-h-0 w-1/2 flex-col items-start justify-start gap-[1.6vh]">
                  <p class="mb-2 text-[2.5vh] leading-[1.25]">
                    {service.description}
                  </p>
                  {service.items.map((item) => (
                    <p class="m-0 text-[2.8vh] font-bold leading-[1.15]">
                      {item}
                    </p>
                  ))}
                </div>
                <img
                  src="/avannubo_icon.png"
                  alt=""
                  class="pointer-events-none absolute bottom-0 -right-[50px] h-auto w-[360px] opacity-10"
                  aria-hidden="true"
                />
              </div>
            </article>
          ))
        }
        <div class="h-[55vh] w-full"></div>
      </div>

      <div class="mb-[120px] flex w-full flex-col items-center justify-start">
        <h3
          class="sticky top-5 z-0 mb-10 mt-0 text-3xl font-bold leading-[1.2]"
        >
          Desarrollo, Optimización y Estrategia
        </h3>
        {
          developmentServices.map((service, index) => (
            <article
              class={`${serviceCard} ${service.topClass} ${index === 0 ? 'mt-0' : 'mt-[120px]'}`}
            >
              <div class="flex w-full items-start justify-between">
                <a href={service.href}>
                  <h3 class={serviceTitle}>{service.title}</h3>
                </a>
                <a
                  href={service.href}
                  class={serviceArrow}
                  aria-label={service.title}
                >
                  <Icon
                    name="ph:arrow-up-right-light"
                    class="h-[4.2vh] w-[4.2vh]"
                  />
                </a>
              </div>
              <div class="flex min-h-0 w-full flex-row items-start justify-start gap-10">
                <img
                  src={service.image}
                  alt={service.alt}
                  class="h-[43vh] w-1/2 rounded-[20px] object-cover"
                />
                <div class="relative flex min-h-0 w-1/2 flex-col items-start justify-start gap-[1.6vh]">
                  <p class="mb-2 text-[2.5vh] leading-[1.25]">
                    {service.description}
                  </p>
                  {service.items.map((item) => (
                    <p class="m-0 text-[2.8vh] font-bold leading-[1.15]">
                      {item}
                    </p>
                  ))}
                </div>
                <img
                  src="/avannubo_icon.png"
                  alt=""
                  class="pointer-events-none absolute bottom-0 -right-[50px] h-auto w-[360px] opacity-10"
                  aria-hidden="true"
                />
              </div>
            </article>
          ))
        }
        <div class="h-[55vh] w-full"></div>
      </div>
    </section>

    <section
      class="relative flex w-full flex-col items-center justify-center p-20 mb-40"
      aria-label="Contacto"
    >
      <h3
        class="scroll-title relative m-0 w-[min(1200px,100%)] text-center text-4xl font-normal leading-[1.2]"
      >
        <b>Avannubo, Tu Partner Tecnológico</b>
      </h3>
      <div class="w-full flex flex-row gap-10 mt-16 mb-10 z-1">
        <div
          class=`w-[30%] ${glassbox} flex flex-col p-6 items-center justify-start gap-2`
        >
          <Icon
            name="ph:users-three-light"
            class="h-18 w-18"
          />
          <h3 class="m-0 text-[30px] font-bold leading-[1.2] p-4 text-center">
            EQUIPO PROFESIONAL
          </h3>
          <p class="mb-4 text-[2.5vh] leading-[1.25] text-center">
            Nuestro equipo de expertos en IT está dedicado a ofrecer soluciones
            personalizadas, eficientes y de alta calidad para impulsar tu
            negocio.
          </p>
        </div>
        <div
          class=`w-[40%] ${glassbox} flex flex-col p-6 items-center justify-start gap-4`
        >
          <Icon
            name="ph:seal-check-light"
            class="h-20 w-20"
          />
          <h3 class="m-0 text-[35px] font-bold leading-[1.2] p-2 text-center">
            TRATO PERSONAL Y DIRECTO
          </h3>
          <p class="mb-4 text-[2.5vh] leading-[1.25] text-center">
            En Avannubo, cada cliente es único. Nos comprometemos a entender tus
            necesidades específicas y ofrecerte un servicio personalizado que se
            adapte perfectamente a tu negocio.
          </p>
        </div>
        <div
          class=`w-[30%] ${glassbox} flex flex-col p-6 items-center justify-start gap-4`
        >
          <Icon
            name="ph:trophy-light"
            class="h-18 w-18"
          />
          <h3 class="m-0 text-[30px] font-bold leading-[1.2] p-4 text-center">
            EXPERIENCIA Y CALIDAD
          </h3>
          <p class="mb-4 text-[2.5vh] leading-[1.25] text-center">
            Contamos con años de experiencia en el sector IT y nos enorgullece
            ofrecer soluciones de alta calidad que superan las expectativas de
            nuestros clientes.
          </p>
        </div>
      </div>
      <a
        href="/contacto"
        aria-label="Contacto"
        class={contactButton}
        >CONÓCENOS AHORA <Icon
          name="ph:arrow-right-bold"
          class="h-5 w-5 ml-1.25"
        /></a
      >
      <img
        src="/avannubo_icon.png"
        alt=""
        class="absolute z-0 h-auto w-[800px] opacity-15"
        aria-hidden="true"
      />
    </section>

    <section
      class="relative mb-20 flex min-h-screen w-full flex-col items-center justify-start p-10"
      aria-label="AVANNET"
    >
      <h2
        class="scroll-title mb-10 mt-0 text-center text-[68px] font-bold leading-[1.1]"
      >
        AVANNET (ERP)
      </h2>
      <h3
        class="relative z-[1] mb-10 mt-0 w-[min(1200px,100%)] text-center text-4xl font-normal leading-[1.2]"
      >
        Descubre <b>AVANnet</b>, nuestro propio Software personalizable de
        Gestión de empresas. Todas las funciones que necesites para tu empresa
        en <b>una única aplicación.</b>
      </h3>
      <div class="flex w-[85%] flex-row items-start justify-start gap-10">
        <div
          class="flex w-full flex-row flex-wrap items-start justify-start gap-6"
        >
          {
            avannetFeatures.map((feature) => (
              <div
                class={`flex h-[25vh] w-[calc(25%-18px)] flex-col items-center justify-start gap-4 p-8 ${glassbox}`}
              >
                <Icon
                  name={feature.icon}
                  class="h-15 w-15"
                />
                <p class="m-0 text-center text-[30px] font-bold leading-[1.2]">
                  {feature.text}
                </p>
              </div>
            ))
          }
        </div>
      </div>
      <a
        href="/contacto"
        class={`${contactButton} mt-12`}
        >CONTACTA PARA + INFO</a
      >
    </section>
    <section
      class="relative flex w-full flex-col items-center justify-start p-8 mt-40 mb-40"
      aria-label="AVANNET"
    >
      <h3
        class="scroll-title relative z-[1] mb-10 font-bold mt-0 w-[min(1200px,100%)] text-center text-4xl leading-[1.2]"
      >
        Opiniones de clientes:
      </h3>
      <div
        class="client-reviews-carousel relative w-full px-16 max-md:px-12"
        aria-label="Carrusel de opiniones de clientes"
      >
        <div class="client-reviews-viewport overflow-hidden px-6 py-20">
          <div
            class="client-reviews-track flex cursor-grab touch-pan-y select-none gap-10 active:cursor-grabbing max-md:gap-6"
          >
            {
              clientReviews.map((review) => (
                <article
                  class={`overflow-visible client-review-slide shrink-0 rounded-[20px] p-8 ${glassbox} flex flex-col items-start justify-start gap-4 max-md:p-6`}
                >
                  <div class="absolute -top-12 left-8 p-3 flex items-center justify-center w-[140px] h-[140px] bg-white  rounded-full">
                    <img
                      src={review.logo}
                      alt={`${review.empresa} logo`}
                      class="h-[100px] w-auto object-contain"
                    />
                  </div>
                  <div class="flex items-center justify-center gap-2 mt-20">
                    <Icon
                      name="ph:star-fill"
                      class="h-6 w-6 text-[#ffd000]"
                    />
                    <Icon
                      name="ph:star-fill"
                      class="h-6 w-6 text-[#ffd000]"
                    />
                    <Icon
                      name="ph:star-fill"
                      class="h-6 w-6 text-[#ffd000]"
                    />
                    <Icon
                      name="ph:star-fill"
                      class="h-6 w-6 text-[#ffd000]"
                    />
                    <Icon
                      name="ph:star-fill"
                      class="h-6 w-6 text-[#ffd000]"
                    />
                  </div>

                  <h3 class="text-[3.5vh] font-bold leading-[1.15] mt-2">
                    {review.empresa}
                  </h3>
                  <p class="text-lg leading-[1.45] text-[22px]">
                    {review.nombre}
                  </p>
                  <p class="text-lg leading-[1.45] max-md:text-[16px]">
                    {review.text}
                  </p>
                </article>
              ))
            }
          </div>
        </div>

        <button
          class="cursor-pointer client-reviews-prev absolute left-0 top-1/2 z-[2] flex h-12 w-12 -translate-y-1/2 items-center justify-center bg-transparent text-6xl leading-none text-white transition-all duration-200 ease-in-out hover:-translate-x-0.5 hover:text-[#b60000] disabled:pointer-events-none disabled:opacity-40"
          type="button"
          aria-label="Ver opiniones anteriores"
        >
          <Icon
            name="ph:caret-left-light"
            class="h-11 w-11"
          />
        </button>
        <button
          class="cursor-pointer client-reviews-next absolute right-0 top-1/2 z-[2] flex h-12 w-12 -translate-y-1/2 items-center justify-center bg-transparent text-6xl leading-none text-white transition-all duration-200 ease-in-out hover:translate-x-0.5 hover:text-[#b60000] disabled:pointer-events-none disabled:opacity-40"
          type="button"
          aria-label="Ver opiniones siguientes"
        >
          <Icon
            name="ph:caret-right-light"
            class="h-11 w-11"
          />
        </button>
      </div>
    </section>
    <!-- <section
      class="relative mb-20 flex min-h-screen w-full flex-col items-center justify-start"
      aria-label="AVANBLOG"
