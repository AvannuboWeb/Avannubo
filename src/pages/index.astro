---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';

const glassbox =
  'overflow-hidden rounded-[5px] bg-[rgba(120,120,120,0.5)] shadow-[0_0_10px_rgba(0,0,0,0.5)] backdrop-blur-[30px]';
const serviceCard = `sticky flex h-[55vh] min-h-[520px] w-full flex-col items-start justify-between p-5 ${glassbox}`;
const serviceTitle =
  'm-0 text-[clamp(64px,7vh,82px)] font-bold leading-[0.95] text-white transition-all duration-200 ease-in-out hover:translate-x-0.5 hover:text-[#b60000]';
const serviceArrow =
  'flex h-[6vh] w-[6vh] items-center justify-center rounded bg-[#b60000] text-4xl leading-none shadow-[0_0_10px_rgba(0,0,0,0.4)] transition-all duration-200 ease-in-out hover:translate-x-0.5 hover:-translate-y-0.5 hover:bg-black';
const contactButton =
  'relative z-[1] mt-8 inline-flex min-h-[45px] cursor-pointer items-center justify-center rounded-md bg-[#b60000] px-4 py-3 leading-none transition-all duration-[220ms] ease-in-out hover:-translate-y-0.5 hover:bg-black';

const certifications = [
  { src: '/9001.png', alt: '9001', className: 'h-auto w-[70px]' },
  { src: '/27001.png', alt: '27001', className: 'h-auto w-[70px]' },
  { src: '/ENS.png', alt: 'ENS', className: 'h-auto w-[70px]' },
  { src: '/CNMC_logo.webp', alt: 'CNMC', className: 'h-auto w-[220px]' },
];

const infrastructureServices = [
  {
    title: 'DATA-CENTER',
    href: '/data-center',
    image: '/homeimg/data-center.webp',
    alt: 'Data Center',
    topClass: 'top-[7vh]',
    description:
      'Soluciones de cloud empresarial, virtualización, almacenamiento seguro y continuidad de negocio, todo ello con máxima seguridad y alto rendimiento.',
    items: [
      'CloudAVAN y AVANvault',
      'Suministros Hardware y Software',
      'Migraciones y Planes Backup y DRS',
      'Citrix (Entorno de Virtualización)',
      'Infraestructura y Housing',
      'AVANréplica (replicación en tiempo real)',
    ],
  },
  {
    title: 'SISTEMAS',
    href: '/sistemas',
    image: '/homeimg/sistemas.webp',
    alt: 'Sistemas',
    topClass: 'top-[16vh]',
    description:
      'Somos expertos en sistemas y administración IT, por lo que garantizamos continuidad, productividad y protección con las mejores herramientas.',
    items: [
      'Mantenimiento y Monitorización',
      'Helpdesk y soporte',
      'Ciberseguridad',
      'Gestión de proyectos IT',
      'Microsoft 365',
      'AVANdns (Dominios y DNS)',
    ],
  },
  {
    title: 'REDES',
    href: '/redes',
    image: '/homeimg/redes.webp',
    alt: 'REDES',
    topClass: 'top-[25vh]',
    description:
      'Potenciamos tu infraestructura: analizamos, optimizamos e implementamos redes desde cero, asegurando así la máxima seguridad y rendimiento.',
    items: [
      'Soporte y Asistencia Técnica',
      'Diseño y Planificación de Redes',
      'Seguridad y Protección de Redes',
      'Optimización y Rendimiento',
      'Mantenimiento y Monitorización',
    ],
  },
  {
    title: 'TELEFONÍA IP',
    href: '/telefonia',
    image: '/homeimg/telefonia.webp',
    alt: 'Telefonía IP',
    topClass: 'top-[34vh]',
    description:
      'Sistema de telefonía IP profesional para empresas que buscan control, escalabilidad y, además, eficiencia en sus comunicaciones.',
    items: [
      'Servicios de Telefonía IP - AVANvoip',
      'Telefonía IP integrada - AVANmóvil',
      'Softphone y Extensiones - IPAVANsip',
      'AVANwave + CRM',
    ],
  },
  {
    title: 'INSTALACIONES',
    href: '/instalaciones',
    image: '/homeimg/instalaciones.webp',
    alt: 'Instalaciones',
    topClass: 'top-[43vh]',
    description:
      'Tu infraestructura en buenas manos gracias a instalaciones IT, seguridad y mantenimiento integral, garantizando así un funcionamiento continuo.',
    items: [
      'Consultoría y Asesoramiento Preventa',
      'Instalaciones y Cableados IT',
      'Sistemas de Red Wifi',
      'Saneado de Armarios Rack',
      'Controles de Accesos y CCTV',
      'Mantenimiento y Servicios postventa',
    ],
  },
];

const developmentServices = [
  {
    title: 'ODOO',
    href: '/odoo',
    image: '/homeimg/odoo.webp',
    alt: 'ODOO',
    topClass: 'top-[7vh]',
    description:
      'Adaptamos las herramientas de Odoo a las necesidades específicas de tu empresa. Optimiza procesos y mejora tu eficiencia.',
    items: [
      'Facturación electrónica - Verifactu y SII',
      'Automatización de Procesos',
      'Unificación de programas',
      'Reducción de costes',
      'Rendimiento y productividad',
    ],
  },
  {
    title: 'APLICACIONES',
    href: '/aplicaciones',
    image: '/homeimg/apps.webp',
    alt: 'Aplicaciones',
    topClass: 'top-[16vh]',
    description:
      'Impulsa tu negocio con aplicaciones web a medida, seguras y escalables. De la idea a producción, con calidad, rendimiento y soporte continuo.',
    items: [
      'Consultoría Técnica de Desarrollo',
      'Análisis funcional de procesos',
      'Arquitectura y diseño de software',
      'Desarrollo a medida y Despliegue',
      'Evolución y mantenimiento del software',
    ],
  },
  {
    title: 'WEB',
    href: '/web',
    image: '/homeimg/web.webp',
    alt: 'Web',
    topClass: 'top-[25vh]',
    description:
      'Webs y comercios electrónicos rápidos, seguros y adaptados a tus necesidades y objetivos, combinando diseño, desarrollo y rendimiento.',
    items: [
      'Desarrollo de Web a medida',
      'E-commerce a Medida',
      'Wordpress y Woocommerce',
      'Diseño Web y Apps (UX/UI)',
      'Hosting propio y Certificados SSL',
    ],
  },
  {
    title: 'SEO & MARKETING',
    href: '/seo-marketing',
    image: '/homeimg/seo-marketing.webp',
    alt: 'SEO & Marketing',
    topClass: 'top-[34vh]',
    description:
      'Mejoramos tu presencia online con estrategias de SEO y Marketing efectivas, orientadas a optimizar resultados y aumentar la visibilidad.',
    items: [
      'Posicionamento SEO y GEO',
      'Analítica Web avanzada',
      'Estrategias SEM (Google Ads)',
      'Email Marketing',
      'Gestión de Redes Sociales',
      'Branding y Diseño Grafico',
    ],
  },
];

const avannetFeatures = [
  { icon: 'tabler:headset', text: 'Ticketing y Soporte' },
  { icon: 'tabler:key', text: 'Contraseñas y Seguridad' },
  { icon: 'tabler:file-text', text: 'Gestor de Documentos' },
  { icon: 'tabler:users', text: 'Gestior de Empleados' },
  { icon: 'tabler:calendar-check', text: 'Calendarios y Ausencias' },
  { icon: 'tabler:fingerprint', text: 'Fichajes y Asistencias' },
  { icon: 'tabler:chart-pie', text: 'CRM Comercial y Ventas' },
  { icon: 'tabler:credit-card', text: 'Gestor de Clientes' },
];
---

<BaseLayout
  title="Home"
  description="Inicio de AVNNUBO"
  mainClass="relative z-10 w-full p-0"
>
  <div class="relative z-10 w-full">
    <section
      class="flex min-h-screen w-full flex-col items-center justify-center"
      aria-label="Portada"
    >
      <h2
        id="typing-text"
        class="m-0 flex h-[120px] items-center text-[68px] font-normal leading-none"
      >
        <span id="typing-content"></span>
        <span
          class="ml-0.5 inline-block h-[120px] w-[3px] animate-pulse bg-white align-bottom"
        ></span>
      </h2>
      <h1 class="m-0 text-[110px] font-bold leading-[1.05]">
        Soluciones y servicios IT
      </h1>
      <h2 class="mb-7 mt-0 text-[68px] font-normal leading-[1.1]">
        que impulsan y transforman tu negocio
      </h2>
      <h3 class="mb-4 mt-0 text-3xl font-normal leading-[1.2]">
        Avannubo, your technology partner
      </h3>
      <a
        href="/calidad"
        aria-label="Certificaciones de calidad"
      >
        <div class="mt-8 flex flex-row items-center justify-center gap-2.5">
          {
            certifications.map((cert) => (
              <img
                src={cert.src}
                alt={cert.alt}
                class={cert.className}
              />
            ))
          }
        </div>
      </a>
    </section>

    <section
      class="relative flex w-full flex-col items-center justify-center px-10 py-40"
      aria-label="Partner tecnológico"
    >
      <h3
        class="relative z-[1] m-0 w-[min(1200px,100%)] text-center text-4xl font-normal leading-[1.2]"
      >
        En <b>Avannubo</b>, queremos ser más que un proveedor de Soluciones y
        Servicios IT, queremos ser <b>Tu Partner Tecnológico</b>
      </h3>
      <img
        src="/avannubo_icon.png"
        alt=""
        class="absolute z-0 h-auto w-[440px] opacity-15"
        aria-hidden="true"
      />
    </section>

    <section
      class="relative flex w-full flex-col items-center justify-start px-10 py-[120px]"
      aria-label="Servicios"
    >
      <h2 class="mb-20 mt-0 text-center text-[68px] font-bold leading-[1.1]">
        Servicios Avannubo
      </h2>

      <div class="mb-[120px] flex w-full flex-col items-center justify-start">
        <h3
          class="sticky top-5 z-0 mb-10 mt-0 text-3xl font-normal leading-[1.2]"
        >
          Infraestructura y Conectividad
        </h3>
        {
          infrastructureServices.map((service, index) => (
            <article
              class={`${serviceCard} ${service.topClass} ${index === 0 ? 'mt-0' : 'mt-[120px]'}`}
            >
              <div class="flex w-full items-start justify-between">
                <a href={service.href}>
                  <h3 class={serviceTitle}>{service.title}</h3>
                </a>
                <a
                  href={service.href}
                  class={serviceArrow}
                  aria-label={service.title}
                >
                  🡥
                </a>
              </div>
              <div class="flex min-h-0 w-full flex-row items-start justify-start gap-10">
                <img
                  src={service.image}
                  alt={service.alt}
                  class="h-[min(43vh,410px)] w-1/2 rounded-[5px] object-cover"
                />
                <div class="relative flex min-h-0 w-1/2 flex-col items-start justify-start gap-[18px]">
                  <p class="m-0 text-2xl leading-[1.25]">
                    {service.description}
                  </p>
                  {service.items.map((item) => (
                    <p class="m-0 text-[26px] font-bold leading-[1.15]">
                      {item}
                    </p>
                  ))}
                </div>
                <img
                  src="/avannubo_icon.png"
                  alt=""
                  class="pointer-events-none absolute bottom-0 -right-[50px] h-auto w-[360px] opacity-10"
                  aria-hidden="true"
                />
              </div>
            </article>
          ))
        }
        <div class="h-[55vh] w-full"></div>
      </div>

      <div class="mb-[120px] flex w-full flex-col items-center justify-start">
        <h3
          class="sticky top-5 z-0 mb-10 mt-0 text-3xl font-normal leading-[1.2]"
        >
          Desarrollo, Optimización y Estrategia
        </h3>
        {
          developmentServices.map((service, index) => (
            <article
              class={`${serviceCard} ${service.topClass} ${index === 0 ? 'mt-0' : 'mt-[120px]'}`}
            >
              <div class="flex w-full items-start justify-between">
                <a href={service.href}>
                  <h3 class={serviceTitle}>{service.title}</h3>
                </a>
                <a
                  href={service.href}
                  class={serviceArrow}
                  aria-label={service.title}
                >
                  🡥
                </a>
              </div>
              <div class="flex min-h-0 w-full flex-row items-start justify-start gap-10">
                <img
                  src={service.image}
                  alt={service.alt}
                  class="h-[min(43vh,410px)] w-1/2 rounded-[5px] object-cover"
                />
                <div class="relative flex min-h-0 w-1/2 flex-col items-start justify-start gap-[18px]">
                  <p class="m-0 text-2xl leading-[1.25]">
                    {service.description}
                  </p>
                  {service.items.map((item) => (
                    <p class="m-0 text-[26px] font-bold leading-[1.15]">
                      {item}
                    </p>
                  ))}
                </div>
                <img
                  src="/avannubo_icon.png"
                  alt=""
                  class="pointer-events-none absolute bottom-0 -right-[50px] h-auto w-[360px] opacity-10"
                  aria-hidden="true"
                />
              </div>
            </article>
          ))
        }
        <div class="h-[55vh] w-full"></div>
      </div>
    </section>

    <section
      class="relative flex w-full flex-col items-center justify-center px-10 py-40"
      aria-label="Contacto"
    >
      <h3
        class="relative z-[1] m-0 w-[min(1200px,100%)] text-center text-4xl font-normal leading-[1.2]"
      >
        En <b>Avannubo</b>, queremos ser más que un proveedor de Soluciones y
        Servicios IT, queremos ser <b>Tu Partner Tecnológico</b>
      </h3>
      <a
        href="/contacto"
        aria-label="Contacto"
        class={contactButton}
        >PONTE EN CONTACTO 🡢</a
      >
      <img
        src="/avannubo_icon.png"
        alt=""
        class="absolute z-0 h-auto w-[440px] opacity-15"
        aria-hidden="true"
      />
    </section>

    <section
      class="relative mb-20 flex min-h-screen w-full flex-col items-center justify-start p-10"
      aria-label="AVANNET"
    >
      <h2 class="mb-10 mt-0 text-center text-[68px] font-bold leading-[1.1]">
        AVANNET (ERP)
      </h2>
      <h3
        class="relative z-[1] mb-10 mt-0 w-[min(1200px,100%)] text-center text-4xl font-normal leading-[1.2]"
      >
        Descubre <b>AVANnet</b>, nuestro propio Software de Gestión de empresas
        personalizable. Todas las funciones importantes de tu empresa en <b
          >una única aplicación.</b
        >
      </h3>
      <div class="flex w-[85%] flex-row items-start justify-start gap-10">
        <img
          src="/homeimg/avannet.webp"
          alt="AVANNET"
          class="h-[60vh] w-5/12 rounded-[5px] object-cover"
        />
        <div
          class="flex h-[60vh] w-7/12 flex-row flex-wrap items-start justify-start gap-6"
        >
          {
            avannetFeatures.map((feature) => (
              <div
                class={`flex h-[calc(30vh-12px)] w-[calc(25%-18px)] flex-col items-center justify-center gap-4 p-3 ${glassbox}`}
              >
                <Icon
                  name={feature.icon}
                  class="h-11 w-11"
                />
                <p class="m-0 text-center text-[20px] font-bold leading-[1.2]">
                  {feature.text}
                </p>
              </div>
            ))
          }
        </div>
      </div>
      <a
        href="/contacto"
        class={`${contactButton} mt-12`}
        >CONTACTA PRA + INFO</a
      >
    </section>
  </div>
</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const words = [
      'DATA-CENTER',
      'SISTEMAS',
      'REDES',
      'TELEFONÍA IP',
      'INSTALACIONES',
      'ODOO',
      'APLICACIONES',
      'DESARROLLO WEB',
      'SEO & MARKETING',
    ];

    const contentElement = document.getElementById('typing-content');

    if (!contentElement) return;

    let wordIndex = 0;
    let charIndex = 0;
    let isDeleting = false;

    function type() {
      const currentWord = words[wordIndex];
      contentElement.textContent = currentWord.slice(0, charIndex);

      if (!isDeleting) {
        if (charIndex < currentWord.length) {
          charIndex++;
          setTimeout(type, 100);
        } else {
          isDeleting = true;
          setTimeout(type, 2000);
        }
      } else {
        if (charIndex > 0) {
          charIndex--;
          setTimeout(type, 30);
        } else {
          isDeleting = false;
          wordIndex = (wordIndex + 1) % words.length;
          setTimeout(type, 100);
        }
      }
    }

    type();
  });
</script>
