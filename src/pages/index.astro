<script>
  import gsap from 'gsap';
  import Draggable from 'gsap/Draggable';
  import ScrollTrigger from 'gsap/ScrollTrigger';

  gsap.registerPlugin(Draggable, ScrollTrigger);

  document.addEventListener('DOMContentLoaded', function () {
    const words = [
      'DATA-CENTER',
      'SISTEMAS',
      'REDES',
      'TELEFONÍA IP',
      'INSTALACIONES',
      'ODOO',
      'APLICACIONES',
      'DESARROLLO WEB',
      'SEO & MARKETING',
    ];

    const contentElement = document.getElementById('typing-content');

    if (!contentElement) return;

    let wordIndex = 0;
    let charIndex = 0;
    let isDeleting = false;

    function type() {
      const currentWord = words[wordIndex];
      contentElement.textContent = currentWord.slice(0, charIndex);

      if (!isDeleting) {
        if (charIndex < currentWord.length) {
          charIndex++;
          setTimeout(type, 100);
        } else {
          isDeleting = true;
          setTimeout(type, 2000);
        }
      } else {
        if (charIndex > 0) {
          charIndex--;
          setTimeout(type, 30);
        } else {
          isDeleting = false;
          wordIndex = (wordIndex + 1) % words.length;
          setTimeout(type, 100);
        }
      }
    }

    type();
  });

  document.addEventListener('DOMContentLoaded', function () {
    const leftToRightTitles = gsap.utils.toArray('.scroll-title');
    const rightToLeftTitles = gsap.utils.toArray('.scroll-title-reverse');

    leftToRightTitles.forEach((title) => {
      gsap.set(title, {
        x: -70,
        autoAlpha: 0,
        clipPath: 'inset(0 100% 0 0)',
      });

      ScrollTrigger.create({
        trigger: title,
        start: 'top 80%',
        once: true,
        onEnter: () => {
          gsap.to(title, {
            x: 0,
            autoAlpha: 1,
            clipPath: 'inset(0 0% 0 0)',
            duration: 2,
            ease: 'power3.out',
          });
        },
      });
    });

    rightToLeftTitles.forEach((title) => {
      gsap.set(title, {
        x: 70,
        autoAlpha: 0,
        clipPath: 'inset(0 0 0 100%)',
      });

      ScrollTrigger.create({
        trigger: title,
        start: 'top 80%',
        once: true,
        onEnter: () => {
          gsap.to(title, {
            x: 0,
            autoAlpha: 1,
            clipPath: 'inset(0 0 0 0%)',
            duration: 2,
            ease: 'power3.out',
          });
        },
      });
    });
  });

  document.addEventListener('DOMContentLoaded', function () {
    const carousel = document.querySelector('.client-reviews-carousel');
    const viewport = carousel?.querySelector('.client-reviews-viewport');
    const track = carousel?.querySelector('.client-reviews-track');
    const slides = carousel?.querySelectorAll('.client-review-slide');
    const prevButton = carousel?.querySelector('.client-reviews-prev');
    const nextButton = carousel?.querySelector('.client-reviews-next');

    if (
      !carousel ||
      !viewport ||
      !track ||
      !slides?.length ||
      !prevButton ||
      !nextButton
    ) {
      return;
    }

    let currentIndex = 0;
    let slidesPerView = 3;
    let slideWidth = 0;
    let gap = 0;
    let maxIndex = 0;
    let draggable;

    function getSlidesPerView() {
      if (window.matchMedia('(max-width: 767px)').matches) return 1;
      if (window.matchMedia('(max-width: 1023px)').matches) return 2;
      return 3;
    }

    function getXForIndex(index) {
      return -index * (slideWidth + gap);
    }

    function updateButtons() {
      prevButton.disabled = currentIndex === 0;
      nextButton.disabled = currentIndex === maxIndex;
    }

    function goToSlide(index, animate = true) {
      currentIndex = gsap.utils.clamp(0, maxIndex, index);

      gsap.to(track, {
        x: getXForIndex(currentIndex),
        duration: animate ? 0.45 : 0,
        ease: 'power3.out',
        onUpdate: () => draggable?.update(),
      });

      updateButtons();
    }

    function setupCarousel() {
      slidesPerView = getSlidesPerView();
      gap = Number.parseFloat(gsap.getProperty(track, 'columnGap')) || 0;
      const vpPaddingLeft =
        Number.parseFloat(getComputedStyle(viewport).paddingLeft) || 0;
      const vpPaddingRight =
        Number.parseFloat(getComputedStyle(viewport).paddingRight) || 0;
      slideWidth =
        (viewport.clientWidth -
          vpPaddingLeft -
          vpPaddingRight -
          gap * (slidesPerView - 1)) /
        slidesPerView;
      maxIndex = Math.max(0, slides.length - slidesPerView);

      slides.forEach((slide) => {
        slide.style.width = `${slideWidth}px`;
        slide.style.height = 'auto';
      });

      const tallestSlideHeight = Math.max(
        ...Array.from(slides).map((slide) => slide.scrollHeight)
      );

      slides.forEach((slide) => {
        slide.style.height = `${tallestSlideHeight}px`;
      });

      currentIndex = gsap.utils.clamp(0, maxIndex, currentIndex);
      draggable?.kill();

      draggable = Draggable.create(track, {
        type: 'x',
        bounds: {
          minX: getXForIndex(maxIndex),
          maxX: 0,
        },
        inertia: false,
        edgeResistance: 0.85,
        dragResistance: 0.08,
        onDragEnd() {
          const rawIndex = Math.round(-this.x / (slideWidth + gap));
          goToSlide(rawIndex);
        },
      })[0];

      goToSlide(currentIndex, false);
    }

    prevButton.addEventListener('click', () => goToSlide(currentIndex - 1));
    nextButton.addEventListener('click', () => goToSlide(currentIndex + 1));
    window.addEventListener('resize', setupCarousel);

    setupCarousel();
  });

  document.addEventListener('DOMContentLoaded', function () {
    const serviceSection = document.querySelector('[aria-label="Servicios"]');
    if (!serviceSection) return;

    const containers = serviceSection.querySelectorAll(':scope > div');
    const targetWidths = [96, 97, 98, 99];

    containers.forEach((container) => {
      const cards = container.querySelectorAll('article.sticky');
      if (!cards.length) return;

      function update() {
        cards.forEach((card, index) => {
          if (index >= targetWidths.length) return;

          const topClass = Array.from(card.classList).find((c) =>
            c.startsWith('top-')
          );
          if (!topClass) return;

          const vhMatch = topClass.match(/\[(\d+(?:\.\d+)?)vh\]/);
          if (!vhMatch) return;

          const topVh = parseFloat(vhMatch[1]);
          const topPx = (topVh * window.innerHeight) / 100;
          const rect = card.getBoundingClientRect();
          const isStuck = rect.top >= 0 && Math.abs(rect.top - topPx) < 5;
          const wasReduced = card.dataset.reduced === 'true';

          if (isStuck) {
            card.style.width = `${targetWidths[index]}%`;
            card.dataset.reduced = 'true';
          } else if (rect.top > topPx && wasReduced) {
            card.style.width = '';
            delete card.dataset.reduced;
          }
        });
      }

      let ticking = false;
      window.addEventListener('scroll', () => {
        if (!ticking) {
          requestAnimationFrame(() => {
            update();
            ticking = false;
          });
          ticking = true;
        }
      });

      update();
    });
  });
</script>
