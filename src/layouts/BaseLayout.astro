---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import { siteName } from '../data/pages';

interface Props {
  title: string;
  description?: string;
  mainClass?: string;
}

const {
  title,
  description = `Pagina de ${title}`,
  mainClass = 'relative z-10 mx-auto w-full px-[40px]',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1"
    />
    <meta
      name="description"
      content={description}
    />
    <meta
      name="generator"
      content={Astro.generator}
    />
    <link
      rel="preconnect"
      href="https://fonts.googleapis.com"
    />
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap"
    />
    <link
      rel="icon"
      type="image/svg+xml"
      href="/favicon.svg"
    />
    <link
      rel="icon"
      href="/favicon.ico"
    />
    <title>{title} | {siteName}</title>
  </head>
  <body
    class="m-0 min-h-screen bg-black font-['Poppins',sans-serif] text-white"
  >
    <div
      class="pointer-events-none fixed inset-0 z-0 h-screen w-screen overflow-hidden"
      aria-hidden="true"
    >
      <video
        class="absolute inset-0 z-0 h-full w-full object-cover"
        autoplay
        muted
        loop
        playsinline
        preload="auto"
      >
        <source
          src="/Avannubo_video.mp4"
          type="video/mp4"
        />
      </video>
      <div
        class="absolute inset-0 z-[1] h-full w-full bg-[linear-gradient(60deg,#b60000_0%,#000_20%)] opacity-[0.85]"
      >
      </div>
    </div>
    <Header />
    <main class={mainClass}>
      <slot />
    </main>
    <Footer />
  </body>
</html>
