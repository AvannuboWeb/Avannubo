---
import { pages, siteName } from "../data/pages";

interface Props {
  title: string;
  description?: string;
}

const { title, description = `Pagina de ${title}` } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title} | {siteName}</title>
  </head>
  <body>
    <header>
      <nav aria-label="Principal">
        <ul>
          {pages.map((page) => {
            const href = page.slug ? `/${page.slug}/` : "/";
            const isActive = currentPath === href;

            return (
              <li>
                <a href={href} aria-current={isActive ? "page" : undefined}>{page.title}</a>
              </li>
            );
          })}
        </ul>
      </nav>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
    font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: #ffffff;
    color: #111827;
    line-height: 1.5;
  }

  header {
    border-bottom: 1px solid #e5e7eb;
    padding: 1rem;
  }

  nav ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  nav a {
    color: #0f172a;
    text-decoration: none;
    border: 1px solid #e2e8f0;
    border-radius: 0.5rem;
    padding: 0.4rem 0.65rem;
    display: inline-block;
    font-size: 0.95rem;
  }

  nav a[aria-current="page"] {
    background: #0f172a;
    border-color: #0f172a;
    color: #ffffff;
  }

  main {
    max-width: 960px;
    margin: 0 auto;
    padding: 2rem 1rem 3rem;
  }

  h1 {
    margin-top: 0;
    line-height: 1.2;
  }
</style>
