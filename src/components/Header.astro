---
import { Icon } from 'astro-icon/components';

const glass =
  'bg-[rgba(160,160,160,0.3)] shadow-[0_4px_30px_rgba(0,0,0,0.1)] backdrop-blur-[25px]';
const glassback =
  'bg-[rgba(0,0,0,0.4)] shadow-[0_4px_30px_rgba(0,0,0,0.1)] backdrop-blur-[35px]';
const hoverRed =
  'transition-all duration-[220ms] ease-in-out hover:-translate-y-0.5 hover:bg-[#b60000]';
const hoverBlack =
  'transition-all duration-[220ms] ease-in-out hover:-translate-y-0.5 hover:bg-[#3d3d3c]';
const menuTitle =
  'm-0 rounded-[10px] px-2.5 py-1 text-[4.6vh] font-bold leading-none transition-all duration-300 ease-in-out hover:translate-x-1 hover:bg-[#b60000]';
const menuTitleSmall =
  'm-0 rounded-[10px] px-2.5 py-1  text-[3vh] font-semibold leading-none transition-all duration-300 ease-in-out hover:translate-x-1 hover:bg-[#b60000]';

const glassocial =
  'bg-[rgba(120,120,120,0.5)] shadow-[0_0_10px_rgba(0,0,0,0.5)] backdrop-blur-[30px]';

const socialItems = [
  {
    href: 'https://www.instagram.com',
    label: 'Instagram',
    icon: 'ph:instagram-logo',
  },
  {
    href: 'https://www.linkedin.com',
    label: 'LinkedIn',
    icon: 'ph:linkedin-logo',
  },
  { href: 'https://maps.google.com', label: 'Mapa', icon: 'ph:map-pin' },
  {
    href: 'mailto:comercial@avannubo.com',
    label: 'Correo',
    icon: 'ph:envelope',
  },
  { href: 'tel:+34932432510', label: 'Telefono', icon: 'ph:phone' },
];

const columnOneItems = [
  {
    tag: 'h3',
    text: 'ERP AVANNUBO',
    className: 'm-0 text-base font-normal leading-[1.2]',
  },
  { tag: 'h2', className: menuTitle, text: 'AVANNET', href: '/' },
  {
    tag: 'h3',
    className: 'm-0 mt-[2vh] text-base font-normal leading-[1.2]',
    text: 'AVANNUBO',
  },
  { tag: 'h2', className: menuTitleSmall, text: 'HOME', href: '/' },
  { tag: 'h2', className: menuTitleSmall, text: 'AVANBLOG', href: '/blog' },
  { tag: 'h2', className: menuTitleSmall, text: 'CALIDAD', href: '/calidad' },
  {
    tag: 'h2',
    className: menuTitleSmall,
    text: 'SOLIDARIDAD',
    href: '/solidaridad',
  },
  {
    tag: 'h3',
    className: 'm-0 mt-[4vh] text-[2vh] font-normal leading-[1.2]',
    text: '+34 93 243 25 10',
    icon: 'ph:arrow-up-right',
  },
  {
    tag: 'h3',
    className: 'm-0 text-[2vh] font-normal leading-[1.2]',
    text: 'comercial@avannubo.com',
    icon: 'ph:arrow-up-right',
  },
  {
    tag: 'h3',
    className: 'm-0 text-[2vh] font-normal leading-[1.2]',
    text: 'C/Almogàvers 80, Barcelona',
    icon: 'ph:arrow-up-right',
  },
];

const columnTwoItems = [
  {
    tag: 'h3',
    className: 'm-0 text-base font-normal leading-[1.2]',
    text: 'TARIFAS Y PRODUCTOS',
  },
  {
    tag: 'h2',
    className: menuTitleSmall,
    text: 'AVANMÓVIL',
    href: '/avanmovil',
  },
  {
    tag: 'h2',
    className: menuTitleSmall,
    text: 'AVANFIBRA',
    href: '/avanfibra',
  },
  { tag: 'h2', className: menuTitleSmall, text: 'CATÁLOGO', href: '/catalogo' },
  {
    tag: 'h3',
    className: 'm-0 mt-[2vh] text-base font-normal leading-[1.2]',
    text: 'HERRAMIENTAS',
  },
  {
    tag: 'h2',
    className: menuTitleSmall,
    text: 'CONTRASEÑAS',
    href: '/contrasenas',
  },
  {
    tag: 'h2',
    className: menuTitleSmall,
    text: 'ENLACES SEGUROS',
    href: '/generador-enlaces',
  },
  {
    tag: 'h3',
    className: 'm-0 mt-[2vh] text-base font-normal leading-[1.2]',
    text: 'ACCESOS',
  },
  {
    tag: 'h2',
    className: menuTitleSmall,
    text: 'ÁREA CLIENTES',
    href: '/contacto',
  },
  {
    tag: 'h2',
    className: menuTitleSmall,
    text: 'AVANVOIP STATS',
    href: '/telefonia',
  },
];

const columnThreeItems = [
  { text: 'INFRAESTRUCTURA', href: '/data-center', icon: 'ph:hard-drives' },
  { text: 'SISTEMAS', href: '/sistemas', icon: 'ph:desktop-tower' },
  { text: 'REDES', href: '/redes', icon: 'ph:network' },
  {
    text: 'CIBERSEGURIDAD',
    href: '/ciberseguridad',
    icon: 'ph:shield-check',
  },
  { text: 'TELEFONÍA IP', href: '/telefonia', icon: 'ph:cell-tower' },
  { text: 'INSTALACIONES', href: '/instalaciones', icon: 'ph:toolbox' },
  { text: 'ODOO', href: '/odoo', icon: 'ph:squares-four' },
  { text: 'APLICACIONES', href: '/aplicaciones', icon: 'ph:devices' },
  { text: 'DESARROLLO WEB', href: '/web', icon: 'ph:code' },
  {
    text: 'SEO & MARKETING',
    href: '/seo-marketing',
    icon: 'ph:megaphone',
  },
];
---

<a
  href="/"
  aria-label="Home"
  class={`fixed left-2.5 top-2.5 z-[999] flex h-[45px] cursor-pointer items-center rounded-[10px] py-3 px-4 bg-[#b60000] ${hoverRed}`}
>
  <img
    src="/Logo_Avannubo_header_bl.png"
    alt="Avannubo"
    class="h-auto w-[155px]"
    loading="eager"
    decoding="async"
  />
</a>

<a
  href="/contacto"
  aria-label="Contacto"
  class={`fixed right-[273px] top-2.5 z-[999] flex h-[45px] cursor-pointer items-center justify-center rounded-[10px] bg-[#b60000] px-4 py-3 text-base font-medium leading-none shadow-[0_0_10px_rgba(0,0,0,0.4)] ${hoverRed}`}
>
  CONTACTO
</a>

<a
  href="/asistencia"
  aria-label="Asistencia Remota"
  class={`fixed right-[70px] top-2.5 z-[999] flex h-[45px] cursor-pointer items-center justify-center rounded-[10px] bg-[#b60000] px-4 py-3 text-base font-medium leading-none shadow-[0_0_10px_rgba(0,0,0,0.4)] ${hoverRed}`}
>
  ASISTENCIA REMOTA
</a>

<div
  id="menu-toggle"
  class={`fixed right-2.5 top-2.5 z-[999] flex h-[45px] w-[50px] cursor-pointer items-center justify-center rounded-[10px] ${glass} ${hoverBlack}`}
  role="button"
  tabindex="0"
  aria-label="Abrir menu"
  aria-expanded="false"
>
  <button
    type="button"
    class="pointer-events-none relative h-5 w-7 border-0 bg-transparent p-0"
    aria-hidden="true"
    tabindex="-1"
  >
    <span
      data-burger-line="top"
      class="absolute left-0 top-0 block h-[2px] w-full rounded-full bg-white transition-all duration-[220ms] ease-in-out"
    ></span>
    <span
      data-burger-line="middle"
      class="absolute left-0 top-[9px] block h-[2px] w-full rounded-full bg-white transition-all duration-[220ms] ease-in-out"
    ></span>
    <span
      data-burger-line="bottom"
      class="absolute left-0 top-[18px] block h-[2px] w-full rounded-full bg-white transition-all duration-[220ms] ease-in-out"
    ></span>
  </button>
</div>

<div
  id="go-top"
  class="pointer-events-none fixed bottom-[60px] right-2.5 z-[980] flex h-10 w-10 translate-x-[calc(100%+10px)] cursor-pointer items-center justify-center rounded-[10px] opacity-0 transition-[transform,opacity] duration-300 ease-in-out"
  role="button"
  tabindex="0"
  aria-label="Go top"
  aria-hidden="true"
>
  <Icon
    name="ph:arrow-up-bold"
    class="h-8 w-8"
  />
</div>

<a
  href="tel:+000000000"
  aria-label="Llamar"
  class="fixed bottom-2.5 right-2.5 z-[980] flex h-[45px] w-[50px] cursor-pointer items-center justify-center rounded-[10px] bg-[#b60000] shadow-[0_0_10px_rgba(0,0,0,0.4)] transition-transform duration-[220ms] ease-in-out hover:-translate-y-0.5"
>
  <Icon
    name="ph:phone"
    class="h-7 w-7 text-white"
  />
</a>

<button
  type="button"
  id="contact-popup-toggle"
  aria-label="Enviar correo"
  aria-haspopup="dialog"
  aria-expanded="false"
  class="fixed bottom-2.5 right-[70px] z-[980] flex h-[45px] w-[50px] cursor-pointer items-center justify-center rounded-[10px] border-0 bg-[#b60000] p-0 shadow-[0_0_10px_rgba(0,0,0,0.4)] transition-transform duration-[220ms] ease-in-out hover:-translate-y-0.5"
>
  <Icon
    name="ph:envelope"
    class="h-7 w-7 text-white"
  />
</button>
<button
  type="button"
  id="chat-popup-toggle"
  aria-label="Abrir chat"
  aria-haspopup="dialog"
  aria-expanded="false"
  class="fixed bottom-2.5 right-[130px] z-[980] flex h-[45px] w-[50px] cursor-pointer items-center justify-center rounded-[10px] border-0 bg-[#b60000] p-0 shadow-[0_0_10px_rgba(0,0,0,0.4)] transition-transform duration-[220ms] ease-in-out hover:-translate-y-0.5"
>
  <Icon
    name="ph:chat-circle-text"
    class="h-7 w-7 text-white"
  />
</button>

<div
  id="contact-popup"
  class="pointer-events-none fixed bottom-[65px] right-[70px] z-[1000] w-[min(420px,calc(100vw-20px))] translate-y-3 opacity-0 transition-all duration-300 ease-in-out"
  role="dialog"
  aria-modal="false"
  aria-labelledby="contact-popup-title"
  aria-hidden="true"
>
  <div
    id="contact-popup-panel"
    class={`relative flex flex-col items-center justify-center gap-4 rounded-[5px] p-6 ${glassocial}`}
  >
    <button
      type="button"
      id="contact-popup-close"
      aria-label="Cerrar formulario"
      class="absolute right-2 top-2 flex h-9 w-9 cursor-pointer items-center justify-center rounded-[10px] border-0 bg-[#b60000] p-0 text-white transition-all duration-[220ms] ease-in-out hover:-translate-y-0.5 hover:bg-black"
    >
      <Icon
        name="ph:x"
        class="h-5 w-5"
      />
    </button>

    <form class="mt-8 flex w-full flex-col gap-4">
      <select
        class="h-11 w-full rounded-[10px] bg-white p-2 text-black placeholder-gray-600 outline-none"
        required
      >
        <option
          value=""
          disabled
          selected
          >Selecciona un departamento</option
        >
        <option value="comercial">Comercial</option>
        <option value="data-center">Data-Center</option>
        <option value="sistemas">Sistemas</option>
        <option value="redes">Redes</option>
        <option value="telefonia-ip">Telefonía IP</option>
        <option value="instalaciones">Instalaciones</option>
        <option value="odoo">Odoo</option>
        <option value="aplicaciones">Aplicaciones</option>
        <option value="desarrollo-web">Desarrollo Web</option>
        <option value="seo-marketing">Seo & Marketing</option>
      </select>

      <input
        type="text"
        class="h-11 w-full rounded-[5px] bg-white p-2 text-black placeholder-gray-600 outline-none"
        placeholder="Nombre completo"
        required
      />

      <div class="flex gap-4">
        <input
          type="email"
          class="h-11 w-full rounded-[5px] bg-white p-2 text-black placeholder-gray-600 outline-none"
          placeholder="Email"
          required
        />
        <input
          type="tel"
          class="h-11 w-full rounded-[5px] bg-white p-2 text-black placeholder-gray-600 outline-none"
          placeholder="Teléfono"
        />
      </div>

      <textarea
        class="h-[90px] w-full resize-none rounded-[5px] bg-white p-2 text-black placeholder-gray-600 outline-none"
        placeholder="Escribe tu consulta..."
        required
      ></textarea>

      <label class="flex cursor-pointer items-center gap-3">
        <input
          type="checkbox"
          class="ml-2 h-5 w-5 accent-[#b60000]"
          required
        />
        <span class="text-sm">
          He leí­do y acepto la <a
            href="/politica-privacidad"
            class="font-bold hover:text-[#b60000]"
            >Polí­tica de Privacidad</a
          >
        </span>
      </label>

      <button
        type="submit"
        class="mt-2 inline-flex min-h-[45px] cursor-pointer items-center justify-center gap-2 rounded-[10px] bg-[#b60000] px-4 py-3 leading-none text-white transition-all duration-[220ms] ease-in-out hover:-translate-y-0.5 hover:bg-black"
        >ENVIAR <Icon
          name="ph:arrow-right"
          class="h-5 w-5"
        /></button
      >
    </form>
  </div>
</div>

<div
  id="chat-popup"
  class="pointer-events-none fixed bottom-[65px] right-[130px] z-[1000] w-[min(420px,calc(100vw-20px))] translate-y-3 opacity-0 transition-all duration-300 ease-in-out max-sm:right-2.5"
  role="dialog"
  aria-modal="false"
  aria-labelledby="chat-popup-title"
  aria-hidden="true"
>
  <div
    id="chat-popup-panel"
    class={`relative flex h-[min(600px,calc(100vh-85px))] min-h-[430px] flex-col overflow-hidden rounded-[5px] ${glassocial}`}
  >
    <button
      type="button"
      id="chat-popup-close"
      aria-label="Cerrar chat"
      class="absolute right-2 top-2 flex h-9 w-9 cursor-pointer items-center justify-center rounded-[5px] border-0 bg-[#b60000] p-0 text-white transition-all duration-[220ms] ease-in-out hover:-translate-y-0.5 hover:bg-black"
    >
      <Icon
        name="ph:x"
        class="h-5 w-5"
      />
    </button>

    <div
      class="flex items-center gap-3 border-b border-white/15 px-5 py-4 pr-14"
    >
      <div
        class="flex h-10 w-10 shrink-0 items-center justify-center rounded-[5px] bg-[#b60000] text-lg font-bold text-white shadow-[0_0_10px_rgba(0,0,0,0.25)]"
        aria-hidden="true"
      >
        A
      </div>
      <div class="min-w-0">
        <h2
          id="chat-popup-title"
          class="m-0 text-base font-bold leading-tight"
        >
          Asistente Avannubo
        </h2>
        <p
          class="m-0 flex items-center gap-2 text-xs leading-none text-white/75"
        >
          <span class="h-2 w-2 rounded-full bg-[#39d353]"></span>
          En linea
        </p>
      </div>
    </div>

    <div
      id="chat-popup-messages"
      class="chat-scrollbar-hidden flex min-h-0 flex-1 basis-0 flex-col gap-3 overflow-y-auto px-5 py-5"
      aria-live="polite"
    >
    </div>

    <div
      id="chat-popup-input-area"
      class="shrink-0 border-t border-white/15 px-4 py-4"
    >
      <div class="flex items-end gap-3 rounded-[5px]">
        <textarea
          id="chat-popup-input"
          rows="1"
          class="max-h-28 min-h-11 min-w-0 flex-1 resize-none rounded-[5px] bg-white p-3 text-sm text-black placeholder-gray-600 outline-none disabled:cursor-not-allowed disabled:bg-white/70 disabled:text-black/50"
          placeholder="Escribe tu consulta..."
          disabled
        ></textarea>
        <button
          type="button"
          id="chat-popup-send"
          class="flex h-11 w-11 shrink-0 cursor-pointer items-center justify-center rounded-[5px] border-0 bg-[#b60000] p-0 text-white transition-all duration-[220ms] ease-in-out hover:-translate-y-0.5 hover:bg-black disabled:cursor-not-allowed disabled:opacity-55 disabled:hover:translate-y-0 disabled:hover:bg-[#b60000]"
          aria-label="Enviar mensaje"
          disabled
        >
          <Icon
            name="ph:paper-plane-tilt"
            class="h-5 w-5"
          />
        </button>
      </div>
    </div>
  </div>
</div>

<style>
  .chat-scrollbar-hidden {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .chat-scrollbar-hidden::-webkit-scrollbar {
    display: none;
  }
</style>

<div
  class={`fixed -top-[100vh] left-0 z-[990] flex h-full w-full flex-col p-2.5 transition-[top] duration-300 ease-in-out ${glassback}`}
  id="menu"
>
  <div class="grid w-full grid-cols-[28fr_28fr_44fr] gap-2.5 pt-[55px]">
    <div
      class={`flex h-[81vh] flex-col items-start justify-start gap-[2vh] rounded-[20px] pb-10 pl-[10%] pr-10 pt-[70px] ${glass}`}
    >
      {
        columnOneItems.map((item) =>
          item.tag === 'h2' ? (
            <h2 class={item.className}>
              <a href={item.href}>{item.text}</a>
            </h2>
          ) : (
            <h3 class={item.className}>
              {item.text}
              {item.icon && (
                <Icon
                  name={item.icon}
                  class="ml-1 inline h-4 w-4 align-[-2px]"
                />
              )}
            </h3>
          )
        )
      }
    </div>

    <div
      class={`flex h-[81vh] flex-col items-start justify-start gap-[2vh] rounded-[20px] pb-10 pl-[10%] pr-10 pt-[70px] ${glass}`}
    >
      {
        columnTwoItems.map((item) =>
          item.tag === 'h2' ? (
            <h2 class={item.className}>
              <a href={item.href}>{item.text}</a>
            </h2>
          ) : (
            <h3 class={item.className}>{item.text}</h3>
          )
        )
      }
    </div>

    <div
      class={`flex h-[81vh] flex-col items-start justify-start gap-[0.8vh] rounded-[20px] pb-10 pl-[10%] pr-10 pt-[70px] ${glass}`}
    >
      <h3 class="mb-[1.2vh] text-base font-normal leading-[1.2]">
        SERVICIOS IT
      </h3>
      {
        columnThreeItems.map((item) => (
          <h2 class={menuTitle}>
            <a
              href={item.href}
              class="inline-flex items-center gap-3"
            >
              {item.text}
            </a>
          </h2>
        ))
      }
    </div>
  </div>

  <div class="grid w-full grid-cols-[51fr_repeat(5,5fr)] gap-2.5">
    <a
      href="/contacto"
      aria-label="Contacto"
      class={`mt-2.5 flex h-[9vh] items-center justify-start rounded-[20px] pl-[5%] ${glass} ${hoverRed}`}
    >
      <span
        class="inline-flex items-center gap-3 text-[4.6vh] font-bold leading-none"
        >PONTE EN CONTACTO <Icon
          name="ph:arrow-right"
          class="h-[4.6vh] w-[4.6vh]"
        /></span
      >
    </a>

    {
      socialItems.map((item) => (
        <a
          href={item.href}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={item.label}
          class={`mt-2.5 flex h-[9vh] items-center justify-center rounded-[20px] ${glass} ${hoverRed}`}
        >
          <Icon
            name={item.icon}
            class="h-[40px] w-[40px] text-white"
          />
        </a>
      ))
    }
  </div>
</div>

<script>
  const menuToggle = document.querySelector('#menu-toggle');
  const menu = document.querySelector('#menu');
  const goTop = document.querySelector('#go-top');
  const burgerTop = document.querySelector('[data-burger-line="top"]');
  const burgerMiddle = document.querySelector('[data-burger-line="middle"]');
  const burgerBottom = document.querySelector('[data-burger-line="bottom"]');
  const contactPopupToggle = document.querySelector('#contact-popup-toggle');
  const contactPopup = document.querySelector('#contact-popup');
  const contactPopupPanel = document.querySelector('#contact-popup-panel');
  const contactPopupClose = document.querySelector('#contact-popup-close');
  const chatPopupToggle = document.querySelector('#chat-popup-toggle');
  const chatPopup = document.querySelector('#chat-popup');
  const chatPopupPanel = document.querySelector('#chat-popup-panel');
  const chatPopupClose = document.querySelector('#chat-popup-close');
  const chatMessages = document.querySelector('#chat-popup-messages');
  const chatInput = document.querySelector('#chat-popup-input');
  const chatSend = document.querySelector('#chat-popup-send');

  const chatSteps = [
    {
      id: 'intent',
      type: 'options',
      bot: 'Hola. Soy el asistente virtual de Avannubo. En que puedo ayudarte?',
      opts: [
        'Tengo una incidencia',
        'Quiero solicitar un presupuesto',
        'Necesito informacion',
        'Quiero hablar con un tecnico',
      ],
      delay: 1000,
    },
    {
      id: 'area',
      type: 'options',
      bot: 'En que area necesitas ayuda?',
      opts: [
        'Data Center',
        'Sistemas',
        'Redes',
        'Telefonia IP',
        'Instalaciones',
        'Odoo',
        'Aplicaciones',
        'Desarrollo Web',
        'SEO & Marketing',
        'Otro',
      ],
      otherOption: true,
    },
    {
      id: 'description',
      type: 'textarea',
      bot: 'Cuentanos brevemente que necesitas',
      placeholder: 'Escribe tu consulta aqui...',
      optional: true,
      delay: 1000,
    },
    {
      id: 'name',
      type: 'contact_field',
      field: 'name',
      inputType: 'text',
      bot: 'Perfecto. Ahora necesito un par de datos para ponernos en contacto contigo. Como te llamas?',
      placeholder: 'Tu nombre completo...',
      validate: (value) => value.length > 0,
      errorMsg: 'Por favor, dinos tu nombre para continuar.',
      delay: 2000,
    },
    {
      id: 'company',
      type: 'contact_field',
      field: 'company',
      inputType: 'text',
      bot: 'Encantado/a, <NAME>. De que empresa nos contactas?',
      placeholder: 'Nombre de la empresa...',
      optional: true,
      delay: 1900,
    },
    {
      id: 'email',
      type: 'contact_field',
      field: 'email',
      inputType: 'email',
      bot: 'Cual es tu direccion de email?',
      placeholder: 'correo@empresa.com...',
      validate: (value) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value),
      errorMsg: 'Por favor, introduce un email valido.',
      delay: 1400,
    },
    {
      id: 'phone',
      type: 'contact_field',
      field: 'phone',
      inputType: 'tel',
      bot: 'Por ultimo, tienes un telefono de contacto? Si prefieres que te contactemos solo por email, puedes saltarte este paso.',
      placeholder: '+34 600 000 000...',
      optional: true,
      validate: (value) => value === '' || /^\+?[\d\s\-().]{6,20}$/.test(value),
      errorMsg: 'Por favor, introduce un telefono valido.',
      sanitize: (value) => value.replace(/[^\d\s+\-().]/g, ''),
      delay: 1200,
    },
  ];

  let chatStep = 0;
  let chatStarted = false;
  let activeComposerStep = null;
  const leadData = {};

  const escapeHtml = (value) => {
    const div = document.createElement('div');
    div.appendChild(document.createTextNode(String(value)));
    return div.innerHTML;
  };

  const scrollChatBottom = () => {
    if (!chatMessages) return;
    chatMessages.scrollTop = chatMessages.scrollHeight;
  };

  const setChatComposerState = ({ enabled, placeholder }) => {
    if (!(chatInput instanceof HTMLTextAreaElement)) return;
    if (!(chatSend instanceof HTMLButtonElement)) return;

    chatInput.disabled = !enabled;
    chatSend.disabled = !enabled;
    chatInput.placeholder = placeholder;

    if (!enabled) {
      chatInput.value = '';
      activeComposerStep = null;
    }
  };

  const markComposerError = (message) => {
    if (!(chatInput instanceof HTMLTextAreaElement)) return;

    chatInput.classList.add('ring-2', 'ring-[#b60000]');
    chatInput.placeholder = message;
    chatInput.focus();
  };

  const addUserBubble = (text) => {
    if (!chatMessages) return;
    const row = document.createElement('div');
    row.className = 'flex justify-end';
    row.innerHTML =
      '<div class="max-w-[82%] rounded-[5px] bg-[#b60000] px-3 py-2 text-sm leading-[1.35] text-white shadow-[0_0_10px_rgba(0,0,0,0.18)]">' +
      escapeHtml(text) +
      '</div>';
    chatMessages.appendChild(row);
    scrollChatBottom();
  };

  const addBotBubble = (html, delay = 800) =>
    new Promise((resolve) => {
      if (!chatMessages) {
        resolve();
        return;
      }

      const typing = document.createElement('div');
      typing.className = 'flex items-start gap-2';
      typing.innerHTML =
        '<div class="flex h-7 w-7 shrink-0 items-center justify-center rounded-[5px] bg-[#b60000] text-xs font-bold text-white">A</div>' +
        '<div class="flex items-center gap-1 rounded-[5px] bg-white/95 px-3 py-3 text-black shadow-[0_0_10px_rgba(0,0,0,0.18)]">' +
        '<span class="h-1.5 w-1.5 animate-pulse rounded-full bg-black/45"></span>' +
        '<span class="h-1.5 w-1.5 animate-pulse rounded-full bg-black/45 [animation-delay:120ms]"></span>' +
        '<span class="h-1.5 w-1.5 animate-pulse rounded-full bg-black/45 [animation-delay:240ms]"></span>' +
        '</div>';
      chatMessages.appendChild(typing);
      scrollChatBottom();

      window.setTimeout(() => {
        typing.remove();
        const row = document.createElement('div');
        row.className = 'flex items-start gap-2';
        row.innerHTML =
          '<div class="flex h-7 w-7 shrink-0 items-center justify-center rounded-[5px] bg-[#b60000] text-xs font-bold text-white">A</div>' +
          '<div class="max-w-[82%] rounded-[5px] bg-white/95 px-3 py-2 text-sm leading-[1.35] text-black shadow-[0_0_10px_rgba(0,0,0,0.18)]">' +
          html +
          '</div>';
        chatMessages.appendChild(row);
        scrollChatBottom();
        resolve();
      }, delay);
    });

  const showFinalMessage = () => {
    setChatComposerState({
      enabled: false,
      placeholder: 'Consulta enviada',
    });
    addBotBubble(
      'Muchas gracias, ' +
        escapeHtml(leadData.name || '') +
        '. En breve nos pondremos en contacto contigo.',
      1700
    ).then(() => {
      console.log('[Avannubo Chat] Nuevo lead:', leadData);
    });
  };

  const advanceChat = () => {
    if (chatStep >= chatSteps.length) return;
    const currentStep = chatSteps[chatStep];
    chatStep += 1;
    const botMessage = currentStep.bot.replace(
      '<NAME>',
      leadData.name ? escapeHtml(leadData.name) : ''
    );

    addBotBubble(botMessage, currentStep.delay).then(() => {
      if (currentStep.type === 'options') renderChatOptions(currentStep);
      if (currentStep.type === 'textarea') renderChatTextarea(currentStep);
      if (currentStep.type === 'contact_field')
        renderChatContactField(currentStep);
    });
  };

  const renderChatOptions = (currentStep) => {
    if (!chatMessages) return;
    setChatComposerState({
      enabled: false,
      placeholder: 'Selecciona una opcion para continuar...',
    });
    const container = document.createElement('div');
    container.className = 'flex flex-wrap gap-2 pl-9';

    currentStep.opts.forEach((option, index) => {
      const isOther =
        currentStep.otherOption && index === currentStep.opts.length - 1;
      const button = document.createElement('button');
      button.type = 'button';
      button.className =
        'cursor-pointer rounded-[5px] border border-white/20 bg-black/25 px-3 py-2 text-left text-sm text-white transition-all duration-[220ms] hover:-translate-y-0.5 hover:bg-[#b60000] disabled:cursor-default disabled:opacity-60';
      button.textContent = option;

      button.addEventListener('click', () => {
        container.querySelectorAll('button').forEach((item) => {
          item.disabled = true;
        });

        if (isOther) {
          showOtherInput(container, currentStep.id);
          return;
        }

        container.remove();
        addUserBubble(option);
        leadData[currentStep.id] = option;
        advanceChat();
      });

      container.appendChild(button);
    });

    chatMessages.appendChild(container);
    scrollChatBottom();
  };

  const showOtherInput = (container, key) => {
    activeComposerStep = {
      type: 'other',
      key,
      placeholder: 'Indica tu area...',
      validate: (value) => value.length > 0,
      errorMsg: 'Indica tu area para continuar.',
      onSubmit: (value) => {
        container.remove();
        addUserBubble(value);
        leadData[key] = value;
        advanceChat();
      },
    };

    setChatComposerState({
      enabled: true,
      placeholder: activeComposerStep.placeholder,
    });
    scrollChatBottom();
    window.setTimeout(() => chatInput?.focus(), 50);
  };

  const renderChatTextarea = (currentStep) => {
    if (!(chatInput instanceof HTMLTextAreaElement)) return;
    activeComposerStep = {
      type: 'textarea',
      placeholder: currentStep.placeholder || 'Escribe aqui...',
    };
    setChatComposerState({
      enabled: true,
      placeholder: activeComposerStep.placeholder,
    });
    chatInput.value = '';
    window.setTimeout(() => chatInput.focus(), 100);
  };

  const submitChatTextarea = () => {
    submitActiveComposer();
  };

  const submitActiveComposer = () => {
    if (!(chatInput instanceof HTMLTextAreaElement)) return;
    if (chatInput.disabled || !activeComposerStep) return;

    let value = chatInput.value.trim();

    if (activeComposerStep.sanitize) {
      value = activeComposerStep.sanitize(value).trim();
      chatInput.value = value;
    }

    if (activeComposerStep.validate && !activeComposerStep.validate(value)) {
      markComposerError(activeComposerStep.errorMsg || 'Campo requerido.');
      return;
    }

    const stepToSubmit = activeComposerStep;
    setChatComposerState({
      enabled: false,
      placeholder: 'Selecciona una opcion para continuar...',
    });

    if (stepToSubmit.type === 'textarea') {
      if (value) {
        addUserBubble(value);
        leadData.description = value;
      } else {
        leadData.description = '';
      }
      advanceChat();
      return;
    }

    if (stepToSubmit.type === 'contact_field') {
      if (value && stepToSubmit.field === 'name') {
        value = value.replace(/\b\w/g, (character) => character.toUpperCase());
      }

      leadData[stepToSubmit.field] = value;
      if (value) addUserBubble(value);

      if (chatStep >= chatSteps.length) showFinalMessage();
      else advanceChat();
      return;
    }

    if (stepToSubmit.type === 'other') {
      stepToSubmit.onSubmit(value);
    }
  };

  const handleComposerInput = () => {
    if (!(chatInput instanceof HTMLTextAreaElement)) return;
    if (!activeComposerStep) return;

    if (activeComposerStep.sanitize) {
      const position = chatInput.selectionStart || 0;
      const cleanValue = activeComposerStep.sanitize(chatInput.value);
      if (cleanValue !== chatInput.value) {
        chatInput.value = cleanValue;
        chatInput.setSelectionRange(
          Math.max(position - 1, 0),
          Math.max(position - 1, 0)
        );
      }
    }

    chatInput.classList.remove('ring-2', 'ring-[#b60000]');
    if (activeComposerStep.placeholder) {
      chatInput.placeholder = activeComposerStep.placeholder;
    }
  };

  const renderChatContactField = (currentStep) => {
    if (!(chatInput instanceof HTMLTextAreaElement)) return;
    activeComposerStep = {
      type: 'contact_field',
      field: currentStep.field,
      placeholder: currentStep.placeholder || '',
      validate: currentStep.validate,
      errorMsg: currentStep.errorMsg,
      sanitize: currentStep.sanitize,
    };
    setChatComposerState({
      enabled: true,
      placeholder: activeComposerStep.placeholder,
    });
    chatInput.value = '';
    window.setTimeout(() => chatInput.focus(), 100);
  };

  const startChat = () => {
    if (chatStarted) return;
    chatStarted = true;
    window.setTimeout(advanceChat, 400);
  };

  const setMenuState = (isOpen) => {
    menu?.classList.toggle('top-0', isOpen);
    menu?.classList.toggle('-top-[100vh]', !isOpen);
    burgerTop?.classList.toggle('translate-y-[9px]', isOpen);
    burgerTop?.classList.toggle('rotate-45', isOpen);
    burgerMiddle?.classList.toggle('opacity-0', isOpen);
    burgerBottom?.classList.toggle('-translate-y-[9px]', isOpen);
    burgerBottom?.classList.toggle('-rotate-45', isOpen);
  };

  const toggleMenu = () => {
    if (!menuToggle || !menu) return;

    const isOpen = menuToggle.getAttribute('aria-expanded') !== 'true';
    setMenuState(isOpen);
    menuToggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    menuToggle.setAttribute(
      'aria-label',
      isOpen ? 'Cerrar menu' : 'Abrir menu'
    );
  };

  if (menuToggle && menu) {
    menuToggle.addEventListener('click', toggleMenu);
    menuToggle.addEventListener('keydown', (event) => {
      if (event.key === 'Enter' || event.key === ' ') {
        event.preventDefault();
        toggleMenu();
      }
    });
  }

  const setContactPopupState = (isOpen) => {
    if (!contactPopup || !contactPopupToggle || !contactPopupPanel) return;

    contactPopup.classList.toggle('translate-y-0', isOpen);
    contactPopup.classList.toggle('translate-y-3', !isOpen);
    contactPopup.classList.toggle('opacity-100', isOpen);
    contactPopup.classList.toggle('opacity-0', !isOpen);
    contactPopup.classList.toggle('pointer-events-auto', isOpen);
    contactPopup.classList.toggle('pointer-events-none', !isOpen);
    contactPopup.setAttribute('aria-hidden', isOpen ? 'false' : 'true');
    contactPopupToggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');

    if (isOpen) {
      contactPopupClose?.focus();
    } else if (contactPopup.contains(document.activeElement)) {
      contactPopupToggle.focus();
    }
  };

  const setChatPopupState = (isOpen) => {
    if (!chatPopup || !chatPopupToggle || !chatPopupPanel) return;

    chatPopup.classList.toggle('translate-y-0', isOpen);
    chatPopup.classList.toggle('translate-y-3', !isOpen);
    chatPopup.classList.toggle('opacity-100', isOpen);
    chatPopup.classList.toggle('opacity-0', !isOpen);
    chatPopup.classList.toggle('pointer-events-auto', isOpen);
    chatPopup.classList.toggle('pointer-events-none', !isOpen);
    chatPopup.setAttribute('aria-hidden', isOpen ? 'false' : 'true');
    chatPopupToggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');

    if (isOpen) {
      startChat();
      const focusTarget =
        chatInput instanceof HTMLTextAreaElement && !chatInput.disabled
          ? chatInput
          : chatPopupClose;
      focusTarget?.focus();
      setContactPopupState(false);
    } else if (chatPopup.contains(document.activeElement)) {
      chatPopupToggle.focus();
    }
  };

  if (contactPopupToggle && contactPopup && contactPopupClose) {
    contactPopupToggle.addEventListener('click', () => {
      const isOpen = contactPopup.getAttribute('aria-hidden') === 'false';
      if (!isOpen) setChatPopupState(false);
      setContactPopupState(!isOpen);
    });

    contactPopupClose.addEventListener('click', () => {
      setContactPopupState(false);
    });

    document.addEventListener('click', (event) => {
      const target = event.target;

      if (!(target instanceof Node)) return;

      const isOpen = contactPopup.getAttribute('aria-hidden') === 'false';
      const isOutsidePopup = !contactPopup.contains(target);
      const isOutsideToggle = !contactPopupToggle.contains(target);

      if (isOpen && isOutsidePopup && isOutsideToggle) {
        setContactPopupState(false);
      }
    });

    document.addEventListener('keydown', (event) => {
      if (
        event.key === 'Escape' &&
        contactPopup.getAttribute('aria-hidden') === 'false'
      ) {
        setContactPopupState(false);
      }
    });
  }

  if (chatPopupToggle && chatPopup && chatPopupClose) {
    chatPopupToggle.addEventListener('click', () => {
      const isOpen = chatPopup.getAttribute('aria-hidden') === 'false';
      setChatPopupState(!isOpen);
    });

    chatPopupPanel?.addEventListener('click', (event) => {
      event.stopPropagation();
    });

    chatPopupClose.addEventListener('click', () => {
      setChatPopupState(false);
    });

    chatSend?.addEventListener('click', submitChatTextarea);
    chatInput?.addEventListener('keydown', (event) => {
      if (event.key === 'Enter' && !event.shiftKey) {
        event.preventDefault();
        submitChatTextarea();
      }
    });
    chatInput?.addEventListener('input', handleComposerInput);

    document.addEventListener('click', (event) => {
      const target = event.target;

      if (!(target instanceof Node)) return;

      const isOpen = chatPopup.getAttribute('aria-hidden') === 'false';
      const isOutsidePopup = !chatPopup.contains(target);
      const isOutsideToggle = !chatPopupToggle.contains(target);

      if (isOpen && isOutsidePopup && isOutsideToggle) {
        setChatPopupState(false);
      }
    });

    document.addEventListener('keydown', (event) => {
      if (
        event.key === 'Escape' &&
        chatPopup.getAttribute('aria-hidden') === 'false'
      ) {
        setChatPopupState(false);
      }
    });
  }

  if (goTop) {
    const toggleGoTop = () => {
      const scrollTrigger = window.innerHeight * 0.006;
      const isVisible = window.scrollY > scrollTrigger;

      goTop.classList.toggle('opacity-100', isVisible);
      goTop.classList.toggle('opacity-0', !isVisible);
      goTop.classList.toggle('translate-x-0', isVisible);
      goTop.classList.toggle('translate-x-[calc(100%+10px)]', !isVisible);
      goTop.classList.toggle('pointer-events-auto', isVisible);
      goTop.classList.toggle('pointer-events-none', !isVisible);
      goTop.setAttribute('aria-hidden', isVisible ? 'false' : 'true');
    };

    const scrollToTop = () => {
      window.scrollTo({
        top: 0,
        behavior: 'smooth',
      });
    };

    goTop.addEventListener('click', scrollToTop);
    goTop.addEventListener('keydown', (event) => {
      if (event.key === 'Enter' || event.key === ' ') {
        event.preventDefault();
        scrollToTop();
      }
    });

    toggleGoTop();
    window.addEventListener('scroll', toggleGoTop, { passive: true });
  }
</script>
