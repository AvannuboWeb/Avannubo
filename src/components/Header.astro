  <div class="grid w-full grid-cols-[51fr_repeat(7,7fr)] gap-2.5">
    <a
      href="/contacto"
      aria-label="Contacto"
      class={`mt-2.5 flex h-[9vh] items-center justify-start rounded-md pl-[5%] ${glass} ${hoverRed}`}
    >
      <span
        class="inline-flex items-center gap-3 text-[4.6vh] font-semibold leading-none"
        >PONTE EN CONTACTO <Icon
          name="tabler:arrow-right"
          class="h-[4.6vh] w-[4.6vh]"
        /></span
      >
