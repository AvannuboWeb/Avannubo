</div>

<script>
  const menuToggle = document.querySelector('#menu-toggle');
  const menu = document.querySelector('#menu');
  const goTop = document.querySelector('#go-top');
  const burgerTop = document.querySelector('[data-burger-line="top"]');
  const burgerMiddle = document.querySelector('[data-burger-line="middle"]');
  const burgerBottom = document.querySelector('[data-burger-line="bottom"]');
  const contactPopupToggle = document.querySelector('#contact-popup-toggle');
  const contactPopup = document.querySelector('#contact-popup');
  const contactPopupPanel = document.querySelector('#contact-popup-panel');
  const contactPopupClose = document.querySelector('#contact-popup-close');
  const chatPopupToggle = document.querySelector('#chat-popup-toggle');
  const chatPopup = document.querySelector('#chat-popup');
  const chatPopupPanel = document.querySelector('#chat-popup-panel');
  const chatPopupClose = document.querySelector('#chat-popup-close');

  const setMenuState = (isOpen) => {
    menu?.classList.toggle('top-0', isOpen);
    menu?.classList.toggle('-top-[100vh]', !isOpen);
    burgerTop?.classList.toggle('translate-y-[9px]', isOpen);
    burgerTop?.classList.toggle('rotate-45', isOpen);
    burgerMiddle?.classList.toggle('opacity-0', isOpen);
    burgerBottom?.classList.toggle('-translate-y-[9px]', isOpen);
    burgerBottom?.classList.toggle('-rotate-45', isOpen);
  };

  const toggleMenu = () => {
    if (!menuToggle || !menu) return;

    const isOpen = menuToggle.getAttribute('aria-expanded') !== 'true';
    setMenuState(isOpen);
    menuToggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    menuToggle.setAttribute(
      'aria-label',
      isOpen ? 'Cerrar menu' : 'Abrir menu'
    );
  };

  if (menuToggle && menu) {
    menuToggle.addEventListener('click', toggleMenu);
    menuToggle.addEventListener('keydown', (event) => {
      if (event.key === 'Enter' || event.key === ' ') {
        event.preventDefault();
        toggleMenu();
      }
    });
  }

  const setContactPopupState = (isOpen) => {
    if (!contactPopup || !contactPopupToggle || !contactPopupPanel) return;

    contactPopup.classList.toggle('translate-y-0', isOpen);
    contactPopup.classList.toggle('translate-y-3', !isOpen);
    contactPopup.classList.toggle('opacity-100', isOpen);
    contactPopup.classList.toggle('opacity-0', !isOpen);
    contactPopup.classList.toggle('pointer-events-auto', isOpen);
    contactPopup.classList.toggle('pointer-events-none', !isOpen);
    contactPopup.setAttribute('aria-hidden', isOpen ? 'false' : 'true');
    contactPopupToggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');

    if (isOpen) {
      contactPopupClose?.focus();
    }
  };

  const setChatPopupState = (isOpen) => {
    if (!chatPopup || !chatPopupToggle || !chatPopupPanel) return;

    chatPopup.classList.toggle('translate-y-0', isOpen);
    chatPopup.classList.toggle('translate-y-3', !isOpen);
    chatPopup.classList.toggle('opacity-100', isOpen);
    chatPopup.classList.toggle('opacity-0', !isOpen);
    chatPopup.classList.toggle('pointer-events-auto', isOpen);
    chatPopup.classList.toggle('pointer-events-none', !isOpen);
    chatPopup.setAttribute('aria-hidden', isOpen ? 'false' : 'true');
    chatPopupToggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');

    if (isOpen) {
      chatPopupClose?.focus();
      setContactPopupState(false);
    }
  };

  if (contactPopupToggle && contactPopup && contactPopupClose) {
    contactPopupToggle.addEventListener('click', () => {
      const isOpen = contactPopup.getAttribute('aria-hidden') === 'false';
      if (!isOpen) setChatPopupState(false);
      setContactPopupState(!isOpen);
    });

    contactPopupClose.addEventListener('click', () => {
      setContactPopupState(false);
    });

    document.addEventListener('click', (event) => {
      const target = event.target;

      if (!(target instanceof Node)) return;

      const isOpen = contactPopup.getAttribute('aria-hidden') === 'false';
      const isOutsidePopup = !contactPopup.contains(target);
      const isOutsideToggle = !contactPopupToggle.contains(target);

      if (isOpen && isOutsidePopup && isOutsideToggle) {
        setContactPopupState(false);
      }
    });

    document.addEventListener('keydown', (event) => {
      if (
        event.key === 'Escape' &&
        contactPopup.getAttribute('aria-hidden') === 'false'
      ) {
        setContactPopupState(false);
      }
    });
  }

  if (chatPopupToggle && chatPopup && chatPopupClose) {
    chatPopupToggle.addEventListener('click', () => {
      const isOpen = chatPopup.getAttribute('aria-hidden') === 'false';
      setChatPopupState(!isOpen);
    });

    chatPopupClose.addEventListener('click', () => {
      setChatPopupState(false);
    });

    document.addEventListener('click', (event) => {
      const target = event.target;

      if (!(target instanceof Node)) return;

      const isOpen = chatPopup.getAttribute('aria-hidden') === 'false';
      const isOutsidePopup = !chatPopup.contains(target);
      const isOutsideToggle = !chatPopupToggle.contains(target);

      if (isOpen && isOutsidePopup && isOutsideToggle) {
        setChatPopupState(false);
      }
    });

    document.addEventListener('keydown', (event) => {
      if (
        event.key === 'Escape' &&
        chatPopup.getAttribute('aria-hidden') === 'false'
      ) {
        setChatPopupState(false);
      }
    });
  }

  if (goTop) {
    const toggleGoTop = () => {
      const scrollTrigger = window.innerHeight * 0.006;
      const isVisible = window.scrollY > scrollTrigger;

      goTop.classList.toggle('opacity-100', isVisible);
      goTop.classList.toggle('opacity-0', !isVisible);
      goTop.classList.toggle('translate-x-0', isVisible);
      goTop.classList.toggle('translate-x-[calc(100%+10px)]', !isVisible);
      goTop.classList.toggle('pointer-events-auto', isVisible);
      goTop.classList.toggle('pointer-events-none', !isVisible);
      goTop.setAttribute('aria-hidden', isVisible ? 'false' : 'true');
    };

    const scrollToTop = () => {
      window.scrollTo({
        top: 0,
        behavior: 'smooth',
      });
    };

    goTop.addEventListener('click', scrollToTop);
    goTop.addEventListener('keydown', (event) => {
      if (event.key === 'Enter' || event.key === ' ') {
        event.preventDefault();
        scrollToTop();
      }
    });

    toggleGoTop();
    window.addEventListener('scroll', toggleGoTop, { passive: true });
  }
</script>
