---
import { Icon } from 'astro-icon/components';

const glass =
  'bg-[rgba(120,120,120,0.5)] shadow-[0_4px_30px_rgba(0,0,0,0.1)] backdrop-blur-[30px]';
const glassback =
  'bg-[rgba(10,10,10,0.4)] shadow-[0_4px_30px_rgba(0,0,0,0.1)] backdrop-blur-[30px]';
const hoverRed =
  'transition-all duration-[220ms] ease-in-out hover:-translate-y-0.5 hover:bg-[#b60000]';
const hoverBlack =
  'transition-all duration-[220ms] ease-in-out hover:-translate-y-0.5 hover:bg-black';
const menuTitle =
  'm-0 rounded-[5px] px-2.5 py-1 text-[4.6vh] font-semibold leading-none transition-all duration-300 ease-in-out hover:translate-x-1 hover:bg-[#b60000]';
const menuTitleSmall =
  'm-0 rounded-[5px] px-2.5 py-1 text-[3vh] font-semibold leading-none transition-all duration-300 ease-in-out hover:translate-x-1 hover:bg-[#b60000]';

const socialItems = [
  {
    href: 'https://www.instagram.com',
    label: 'Instagram',
    icon: 'tabler:brand-instagram',
  },
  {
    href: 'https://www.youtube.com',
    label: 'YouTube',
    icon: 'tabler:brand-youtube',
  },
  {
    href: 'https://www.linkedin.com',
    label: 'LinkedIn',
    icon: 'tabler:brand-linkedin',
  },
  { href: 'https://x.com', label: 'X', icon: 'tabler:brand-x' },
  { href: 'https://maps.google.com', label: 'Mapa', icon: 'tabler:map-pin' },
  {
    href: 'mailto:comercial@avannubo.com',
    label: 'Correo',
    icon: 'tabler:mail',
  },
  { href: 'tel:+34932432510', label: 'Telefono', icon: 'tabler:phone' },
];

const columnOneItems = [
  {
    tag: 'h3',
    text: 'ERP AVANNUBO',
    className: 'm-0 text-base font-normal leading-[1.2]',
  },
  { tag: 'h2', className: menuTitle, text: 'AVANNET', href: '/' },
  {
    tag: 'h3',
    className: 'm-0 mt-[2vh] text-base font-normal leading-[1.2]',
    text: 'HERRAMIENTAS',
  },
  {
    tag: 'h2',
    className: menuTitleSmall,
    text: 'CONTRASEÑAS',
    href: '/contrasenas',
  },
  {
    tag: 'h2',
    className: menuTitleSmall,
    text: 'ENLACES SEGUROS',
    href: '/generador-enlaces',
  },
  {
    tag: 'h3',
    className: 'm-0 mt-[2vh] text-base font-normal leading-[1.2]',
    text: 'ACCESOS',
  },
  {
    tag: 'h2',
    className: menuTitleSmall,
    text: 'ÁREA CLIENTES',
    href: '/contacto',
  },
  {
    tag: 'h2',
    className: menuTitleSmall,
    text: 'AVANVOIP STATS',
    href: '/telefonia',
  },
  {
    tag: 'h3',
    className: 'm-0 mt-[3vh] text-base font-normal leading-[1.2]',
    text: '+34 93 243 25 10 🡥',
  },
  {
    tag: 'h3',
    className: 'm-0 text-base font-normal leading-[1.2]',
    text: 'comercial@avannubo.com 🡥',
  },
  {
    tag: 'h3',
    className: 'm-0 text-base font-normal leading-[1.2]',
    text: 'C/Almogàvers 80, Barcelona 🡥',
  },
];

const columnTwoItems = [
  {
    tag: 'h3',
    className: 'm-0 text-base font-normal leading-[1.2]',
    text: 'TARIFAS Y PRODUCTOS',
  },
  {
    tag: 'h2',
    className: menuTitleSmall,
    text: 'AVANMÓVIL',
    href: '/avanmovil',
  },
  {
    tag: 'h2',
    className: menuTitleSmall,
    text: 'AVANFIBRA',
    href: '/avanfibra',
  },
  { tag: 'h2', className: menuTitleSmall, text: 'CATÁLOGO', href: '/catalogo' },
  {
    tag: 'h3',
    className: 'm-0 mt-[2vh] text-base font-normal leading-[1.2]',
    text: 'AVANNUBO',
  },
  { tag: 'h2', className: menuTitleSmall, text: 'HOME', href: '/' },
  { tag: 'h2', className: menuTitleSmall, text: 'AVANBLOG', href: '/blog' },
  { tag: 'h2', className: menuTitleSmall, text: 'CALIDAD', href: '/calidad' },
  {
    tag: 'h2',
    className: menuTitleSmall,
    text: 'SOLIDARIDAD',
    href: '/solidaridad',
  },
];

const columnThreeItems = [
  { text: 'DATA-CENTER', href: '/data-center' },
  { text: 'SISTEMAS', href: '/sistemas' },
  { text: 'REDES', href: '/redes' },
  { text: 'TELEFONÍA IP', href: '/telefonia' },
  { text: 'INSTALACIONES', href: '/instalaciones' },
  { text: 'ODOO', href: '/odoo' },
  { text: 'APLICACIONES', href: '/aplicaciones' },
  { text: 'WEB', href: '/web' },
  { text: 'SEO & MARKETING', href: '/seo-marketing' },
];
---

<a
  href="/"
  aria-label="Home"
  class={`fixed left-2.5 top-2.5 z-[999] flex h-[45px] cursor-pointer items-center rounded-md p-3 ${glass} ${hoverRed}`}
>
  <img
    src="/Logo_Avannubo_header_bl.png"
    alt="Avannubo"
    class="h-auto w-[155px]"
    loading="eager"
    decoding="async"
  />
</a>

<a
  href="/contacto"
  aria-label="Contacto"
  class={`fixed right-[273px] top-2.5 z-[999] flex h-[45px] cursor-pointer items-center justify-center rounded-md bg-[#b60000] px-4 py-3 text-base font-medium leading-none shadow-[0_0_10px_rgba(0,0,0,0.4)] ${hoverBlack}`}
>
  CONTACTO
</a>

<a
  href="/asistencia"
  aria-label="Asistencia Remota"
  class={`fixed right-[70px] top-2.5 z-[999] flex h-[45px] cursor-pointer items-center justify-center rounded-md bg-[#b60000] px-4 py-3 text-base font-medium leading-none shadow-[0_0_10px_rgba(0,0,0,0.4)] ${hoverBlack}`}
>
  ASISTENCIA REMOTA
</a>

<div
  id="menu-toggle"
  class={`fixed right-2.5 top-2.5 z-[999] flex h-[45px] w-[50px] cursor-pointer items-center justify-center rounded-md ${glass} ${hoverRed}`}
  role="button"
  tabindex="0"
  aria-label="Abrir menu"
  aria-expanded="false"
>
  <button
    type="button"
    class="pointer-events-none relative h-5 w-7 border-0 bg-transparent p-0"
    aria-hidden="true"
    tabindex="-1"
  >
    <span
      data-burger-line="top"
      class="absolute left-0 top-0 block h-[2px] w-full rounded-full bg-white transition-all duration-[220ms] ease-in-out"
    ></span>
    <span
      data-burger-line="middle"
      class="absolute left-0 top-[9px] block h-[2px] w-full rounded-full bg-white transition-all duration-[220ms] ease-in-out"
    ></span>
    <span
      data-burger-line="bottom"
      class="absolute left-0 top-[18px] block h-[2px] w-full rounded-full bg-white transition-all duration-[220ms] ease-in-out"
    ></span>
  </button>
</div>

<div
  id="go-top"
  class="pointer-events-none fixed bottom-[60px] right-2.5 z-[980] flex h-10 w-10 translate-x-[calc(100%+10px)] cursor-pointer items-center justify-center rounded-md opacity-0 transition-[transform,opacity] duration-300 ease-in-out"
  role="button"
  tabindex="0"
  aria-label="Go top"
  aria-hidden="true"
>
  <span class="text-2xl leading-none">🡡</span>
</div>

<a
  href="tel:+000000000"
  aria-label="Llamar"
  class="fixed bottom-2.5 right-2.5 z-[980] flex h-[45px] w-[45px] cursor-pointer items-center justify-center rounded-md bg-[#b60000] shadow-[0_0_10px_rgba(0,0,0,0.4)] transition-transform duration-[220ms] ease-in-out hover:-translate-y-0.5"
>
  <Icon
    name="tabler:phone"
    class="h-5 w-5 text-white"
  />
</a>

<a
  href="mailto:correo@ejemplo.com"
  aria-label="Enviar correo"
  class="fixed bottom-2.5 right-[65px] z-[980] flex h-[45px] w-[45px] cursor-pointer items-center justify-center rounded-md bg-[#b60000] shadow-[0_0_10px_rgba(0,0,0,0.4)] transition-transform duration-[220ms] ease-in-out hover:-translate-y-0.5"
>
  <Icon
    name="tabler:mail"
    class="h-5 w-5 text-white"
  />
</a>

<div
  class={`fixed -top-[100vh] left-0 z-[990] flex h-full w-full flex-col p-2.5 transition-[top] duration-300 ease-in-out ${glassback}`}
  id="menu"
>
  <div class="grid w-full grid-cols-[28fr_28fr_44fr] gap-2.5 pt-[55px]">
    <div
      class={`flex h-[81vh] flex-col items-start justify-start gap-[2vh] rounded-md pb-10 pl-[10%] pr-10 pt-[70px] ${glass}`}
    >
      {
        columnOneItems.map((item) =>
          item.tag === 'h2' ? (
            <h2 class={item.className}>
              <a href={item.href}>{item.text}</a>
            </h2>
          ) : (
            <h3 class={item.className}>{item.text}</h3>
          )
        )
      }
    </div>

    <div
      class={`flex h-[81vh] flex-col items-start justify-start gap-[2vh] rounded-md pb-10 pl-[10%] pr-10 pt-[70px] ${glass}`}
    >
      {
        columnTwoItems.map((item) =>
          item.tag === 'h2' ? (
            <h2 class={item.className}>
              <a href={item.href}>{item.text}</a>
            </h2>
          ) : (
            <h3 class={item.className}>{item.text}</h3>
          )
        )
      }
    </div>

    <div
      class={`flex h-[81vh] flex-col items-start justify-start gap-[1.2vh] rounded-md pb-10 pl-[10%] pr-10 pt-[70px] ${glass}`}
    >
      <h3 class="m-0 text-base font-normal leading-[1.2]">SERVICIOS IT</h3>
      {
        columnThreeItems.map((item) => (
          <h2 class={menuTitle}>
            <a href={item.href}>{item.text}</a>
          </h2>
        ))
      }
    </div>
  </div>

  <div class="grid w-full grid-cols-[51fr_repeat(7,7fr)] gap-2.5">
    <a
      href="/contacto"
      aria-label="Contacto"
      class={`mt-2.5 flex h-[9vh] items-center justify-start rounded-md pl-[5%] ${glass} ${hoverRed}`}
    >
      <span class="text-[4.6vh] font-semibold leading-none"
        >PONTE EN CONTACTO 🡢</span
      >
    </a>

    {
      socialItems.map((item) => (
        <a
          href={item.href}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={item.label}
          class={`mt-2.5 flex h-[9vh] items-center justify-center rounded-md ${glass} ${hoverRed}`}
        >
          <Icon
            name={item.icon}
            class="h-[30px] w-[30px] text-white"
          />
        </a>
      ))
    }
  </div>
</div>

<script>
  const menuToggle = document.querySelector('#menu-toggle');
  const menu = document.querySelector('#menu');
  const goTop = document.querySelector('#go-top');
  const burgerTop = document.querySelector('[data-burger-line="top"]');
  const burgerMiddle = document.querySelector('[data-burger-line="middle"]');
  const burgerBottom = document.querySelector('[data-burger-line="bottom"]');

  const setMenuState = (isOpen) => {
    menu?.classList.toggle('top-0', isOpen);
    menu?.classList.toggle('-top-[100vh]', !isOpen);
    burgerTop?.classList.toggle('translate-y-[9px]', isOpen);
    burgerTop?.classList.toggle('rotate-45', isOpen);
    burgerMiddle?.classList.toggle('opacity-0', isOpen);
    burgerBottom?.classList.toggle('-translate-y-[9px]', isOpen);
    burgerBottom?.classList.toggle('-rotate-45', isOpen);
  };

  const toggleMenu = () => {
    if (!menuToggle || !menu) return;

    const isOpen = menuToggle.getAttribute('aria-expanded') !== 'true';
    setMenuState(isOpen);
    menuToggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    menuToggle.setAttribute(
      'aria-label',
      isOpen ? 'Cerrar menu' : 'Abrir menu'
    );
  };

  if (menuToggle && menu) {
    menuToggle.addEventListener('click', toggleMenu);
    menuToggle.addEventListener('keydown', (event) => {
      if (event.key === 'Enter' || event.key === ' ') {
        event.preventDefault();
        toggleMenu();
      }
    });
  }

  if (goTop) {
    const toggleGoTop = () => {
      const scrollTrigger = window.innerHeight * 0.006;
      const isVisible = window.scrollY > scrollTrigger;

      goTop.classList.toggle('opacity-100', isVisible);
      goTop.classList.toggle('opacity-0', !isVisible);
      goTop.classList.toggle('translate-x-0', isVisible);
      goTop.classList.toggle('translate-x-[calc(100%+10px)]', !isVisible);
      goTop.classList.toggle('pointer-events-auto', isVisible);
      goTop.classList.toggle('pointer-events-none', !isVisible);
      goTop.setAttribute('aria-hidden', isVisible ? 'false' : 'true');
    };

    const scrollToTop = () => {
      window.scrollTo({
        top: 0,
        behavior: 'smooth',
      });
    };

    goTop.addEventListener('click', scrollToTop);
    goTop.addEventListener('keydown', (event) => {
      if (event.key === 'Enter' || event.key === ' ') {
        event.preventDefault();
        scrollToTop();
      }
    });

    toggleGoTop();
    window.addEventListener('scroll', toggleGoTop, { passive: true });
  }
</script>
