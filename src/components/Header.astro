      }
    </div>

    <div
      class={`flex h-[81vh] flex-col items-start justify-start gap-[1.2vh] rounded-md pb-10 pl-[10%] pr-10 pt-[70px] ${glass}`}
    >
      <h3 class="m-0 text-base font-normal leading-[1.2]">SERVICIOS IT</h3>
      {
        columnThreeItems.map((item) => (
          <h2 class={menuTitle}>
