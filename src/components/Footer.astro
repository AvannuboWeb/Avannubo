---
import { Icon } from 'astro-icon/components';

const glass =
  'bg-[rgba(120,120,120,0.5)] shadow-[0_4px_30px_rgba(0,0,0,0.1)] backdrop-blur-[30px]';

const links = [
  { href: '/politica-privacidad', label: 'PRIVACIDAD' },
  { href: '/politica-cookies', label: 'COOKIES' },
  { href: '/aviso-legal', label: 'AVISO LEGAL' },
  { href: '/accesibilidad', label: 'ACCESIBILIDAD' },
  { href: '/politica-calidad', label: 'CALIDAD' },
];

const socials = [
  { name: 'ph:instagram-logo', href: '#' },
  { name: 'ph:linkedin-logo', href: '#' },
  { name: 'ph:phone', href: '#' },
  { name: 'ph:envelope', href: '#' },
];

const certs = ['/9001.png', '/27001.png', '/ENS.png'];

const footerLogos = [
  'Ads.webp',
  'Analytics.webp',
  'Cisco.webp',
  'Citrix.webp',
  'css-scaled.webp',
  'docker.webp',
  'ESET.webp',
  'figma.webp',
  'Fortinet.webp',
  'html-scaled.webp',
  'js.webp',
  'laravel.webp',
  'livewire.webp',
  'm365.webp',
  'microsoft-silver.webp',
  'miro.webp',
  'Netgear.webp',
  'netspot.webp',
  'next.webp',
  'nmap.webp',
  'Node.webp',
  'odoo.png',
  'php.webp',
  'Plesk.webp',
  'python.webp',
  'React-1.webp',
  'semrush-scaled.webp',
  'Sophos.webp',
  'Ubiquiti.webp',
  'unifi.webp',
  'Veeam-scaled.webp',
  'Visio.webp',
  'Vmware.webp',
  'wireshark.webp',
  'Zabbix.webp',
];
---

<footer class="relative z-10 flex w-full flex-col gap-2.5 p-2.5">
  <div class={`overflow-hidden rounded-[20px] ${glass}`}>
    <div
      class="js-footer-marquee flex h-[120px] w-max flex-row items-center gap-12 px-6"
      aria-label="Tecnologías y partners"
    >
      {
        [...footerLogos, ...footerLogos].map((logo) => (
          <img
            src={`/footer/${logo}`}
            alt={logo.replace(/\.[^/.]+$/, '').replaceAll('-', ' ')}
            class="h-[35px] w-[120px] shrink-0 object-contain"
          />
        ))
      }
    </div>
  </div>
  <div class="flex h-[36vh] w-full flex-row gap-2.5">
    <div
      class={`flex h-full flex-[1_1_auto] items-center justify-center rounded-[20px] ${glass}`}
    >
      <a
        href="/"
        aria-label="Avannubo"
      >
        <img
          src="/Logo-Avannubo-grande.png"
          alt="Avannubo"
          class="h-auto w-[500px]"
        />
      </a>
    </div>

    <div class="flex h-full basis-[8vh] flex-col gap-2.5 rounded-[20px]">
      {
        socials.map((social) => (
          <a
            href={social.href}
            class={`flex min-h-0 flex-[1_1_0] items-center justify-center rounded-[20px] transition-all duration-300 ease-in-out hover:-translate-y-0.5 hover:bg-[#b60000] ${glass}`}
            aria-label={social.name}
          >
            <Icon
              name={social.name}
              class="h-8 w-8 text-white [&_path]:!stroke-[3]"
            />
          </a>
        ))
      }
    </div>

    <nav
      class={`flex h-full basis-[300px] flex-col items-center justify-center gap-4 rounded-[20px] ${glass}`}
      aria-label="Legal"
    >
      {
        links.map((link) => (
          <a
            href={link.href}
            class="rounded-[10px] px-2.5 py-1 text-xl leading-none transition-all duration-300 ease-in-out hover:-translate-y-0.5 hover:bg-[#b60000]"
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div
      class={`flex h-full basis-[420px] flex-col items-center justify-center gap-4 rounded-[20px] ${glass}`}
    >
      <div class="flex flex-row items-center justify-center gap-2.5">
        {
          certs.map((cert) => (
            <img
              src={cert}
              alt={cert.split('/')[1]}
              class="h-auto w-20"
            />
          ))
        }
      </div>
      <img
        src="/CNMC_logo.webp"
        alt="CNMC"
        class="h-auto w-[248px]"
      />
    </div>
  </div>
</footer>

<script>
  import gsap from 'gsap';

  let footerMarqueeResizeTimer: number | undefined;

  const initFooterMarquee = () => {
    const marquee = document.querySelector<HTMLElement>('.js-footer-marquee');

    if (!marquee) return;

    const reduceMotion = window.matchMedia(
      '(prefers-reduced-motion: reduce)'
    ).matches;

    if (reduceMotion) return;

    const waitForImages = Array.from(marquee.querySelectorAll('img')).map(
      (image) => {
        if (image.complete) return Promise.resolve();

        return new Promise<void>((resolve) => {
          image.addEventListener('load', () => resolve(), { once: true });
          image.addEventListener('error', () => resolve(), { once: true });
        });
      }
    );

    Promise.all(waitForImages).then(() => {
      const distance = marquee.scrollWidth / 2;

      if (!distance) return;

      gsap.killTweensOf(marquee);
      gsap.set(marquee, { x: 0 });

      gsap.to(marquee, {
        x: -distance,
        duration: 38,
        ease: 'none',
        repeat: -1,
        modifiers: {
          x: gsap.utils.unitize((x) => Number.parseFloat(x) % distance),
        },
      });
    });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFooterMarquee, {
      once: true,
    });
  } else {
    initFooterMarquee();
  }

  window.addEventListener('resize', () => {
    window.clearTimeout(footerMarqueeResizeTimer);
    footerMarqueeResizeTimer = window.setTimeout(initFooterMarquee, 150);
  });
</script>
