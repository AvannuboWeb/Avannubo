---
import { Icon } from "astro-icon/components";

const glass = "bg-[rgba(120,120,120,0.5)] shadow-[0_4px_30px_rgba(0,0,0,0.1)] backdrop-blur-[30px]";

const links = [
  { href: "/politica-privacidad", label: "PRIVACIDAD" },
  { href: "/politica-cookies", label: "COOKIES" },
  { href: "/aviso-legal", label: "AVISO LEGAL" },
  { href: "/accesibilidad", label: "ACCESIBILIDAD" },
  { href: "/politica-calidad", label: "CALIDAD" }
];

const socials = [
  { name: "tabler:brand-instagram", href: "#" },
  { name: "tabler:brand-youtube", href: "#" },
  { name: "tabler:brand-x", href: "#" },
  { name: "tabler:brand-linkedin", href: "#" }
];

const certs = ["/9001.png", "/27001.png", "/ENS.png"];
---

<footer class="relative z-10 flex w-full flex-col gap-2.5 p-2.5">
  <div class={`h-[100px] w-full rounded-[5px] ${glass}`}></div>
  <div class="flex h-[32vh] w-full flex-row gap-2.5">
    <div class={`flex h-full flex-[1_1_auto] items-center justify-center rounded-[5px] ${glass}`}>
      <a href="/" aria-label="Avannubo">
        <img src="/Logo-Avannubo-grande.png" alt="Avannubo" class="h-auto w-[500px]" />
      </a>
    </div>

    <div class="flex h-full basis-[8vh] flex-col gap-2.5 rounded-[5px]">
      {socials.map((social) => (
        <a href={social.href} class={`flex min-h-0 flex-[1_1_0] items-center justify-center rounded-[5px] transition-all duration-300 ease-in-out hover:-translate-y-0.5 hover:bg-[#b60000] ${glass}`} aria-label={social.name}>
          <Icon name={social.name} class="h-[30px] w-[30px] text-white" />
        </a>
      ))}
    </div>

    <nav class={`flex h-full basis-[300px] flex-col items-center justify-center gap-4 rounded-[5px] ${glass}`} aria-label="Legal">
      {links.map((link) => (
        <a href={link.href} class="rounded-[5px] px-2.5 py-1 text-lg leading-none transition-all duration-300 ease-in-out hover:-translate-y-0.5 hover:bg-[#b60000]">{link.label}</a>
      ))}
    </nav>

    <div class={`flex h-full basis-[420px] flex-col items-center justify-center gap-4 rounded-[5px] ${glass}`}>
      <div class="flex flex-row items-center justify-center gap-2.5">
        {certs.map((cert) => (
          <img src={cert} alt={cert.split("/")[1]} class="h-auto w-20" />
        ))}
      </div>
      <img src="/CNMC_logo.webp" alt="CNMC" class="h-auto w-[248px]" />
    </div>
  </div>
</footer>
